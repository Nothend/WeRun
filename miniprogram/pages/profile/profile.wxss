/* ══════════════════════════════════════
   授权模式（首次登录）
══════════════════════════════════════ */
.auth-screen {
  min-height: 100vh;
  background: #070d1b;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 100rpx 56rpx 80rpx;
  box-sizing: border-box;
}

/* Hero 区 */
.auth-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.auth-hero-emoji {
  font-size: 80rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}
.auth-hero-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #e2e8f0;
  letter-spacing: 4rpx;
}
.auth-hero-sub {
  font-size: 26rpx;
  color: #64748b;
  letter-spacing: 1rpx;
  text-align: center;
  line-height: 1.6;
}

/* 表单区 */
.auth-form {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 48rpx;
  width: 100%;
}

/* 头像按钮 */
.auth-avatar-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}
.auth-avatar-btn::after { border: none; }
.auth-avatar-wrap {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}
.auth-avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 3rpx dashed rgba(34, 211, 238, 0.5);
  box-shadow: 0 0 40rpx rgba(34, 211, 238, 0.15);
}
.auth-avatar-overlay {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}
.auth-avatar-overlay.set {
  background: rgba(34, 211, 238, 0.25);
}
.auth-avatar-camera {
  font-size: 56rpx;
  line-height: 1;
}
.auth-avatar-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #94a3b8;
  letter-spacing: 1rpx;
}
.auth-avatar-label.done {
  color: #22d3ee;
}

/* 昵称字段 */
.auth-nickname-field {
  width: 100%;
}
.auth-field-label {
  font-size: 24rpx;
  color: #64748b;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.auth-required {
  font-size: 20rpx;
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.12);
  border-radius: 8rpx;
  padding: 2rpx 12rpx;
  letter-spacing: 0;
}
.auth-field-hint {
  font-size: 22rpx;
  color: #eab308;
  margin-bottom: 12rpx;
  line-height: 1.5;
}
.auth-nickname-wrap {
  width: 100%;
  background: rgba(255, 255, 255, 0.04);
  border: 2rpx solid rgba(34, 211, 238, 0.2);
  border-radius: 20rpx;
  padding: 0 32rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-sizing: border-box;
  transition: border-color 0.2s;
}
.auth-nickname-wrap.filled {
  border-color: rgba(34, 211, 238, 0.6);
  background: rgba(34, 211, 238, 0.04);
}
.auth-nickname-input {
  flex: 1;
  height: 104rpx;
  font-size: 34rpx;
  color: #e2e8f0;
}
.auth-nickname-placeholder {
  color: #334155;
}
.auth-nickname-check {
  font-size: 32rpx;
  color: #22d3ee;
  font-weight: 700;
  flex-shrink: 0;
}

/* 底部 */
.auth-bottom {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
}
.auth-social-tip {
  font-size: 24rpx;
  color: #475569;
  letter-spacing: 1rpx;
  background: rgba(34, 211, 238, 0.06);
  border: 1rpx solid rgba(34, 211, 238, 0.1);
  border-radius: 12rpx;
  padding: 14rpx 32rpx;
}
.auth-allow-btn {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #0a0f1a;
  background: linear-gradient(135deg, #0ea5e9, #22d3ee);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(34, 211, 238, 0.45);
  letter-spacing: 2rpx;
}
.auth-allow-btn.saving {
  opacity: 0.6;
}
.auth-allow-btn.disabled {
  background: #1e293b;
  color: #475569;
  box-shadow: none;
  pointer-events: none;
}
.apply-hint {
  font-size: 22rpx;
  color: #64748b;
  text-align: center;
  letter-spacing: 0.5rpx;
  margin-top: -8rpx;
}
.auth-skip-btn {
  font-size: 24rpx;
  color: #334155;
  letter-spacing: 0.5rpx;
  padding: 12rpx 32rpx;
  text-decoration: underline;
  text-decoration-color: #1e293b;
}

/* ══════════════════════════════════════
   普通编辑模式
══════════════════════════════════════ */
.container {
  min-height: 100vh;
  padding: 24rpx 24rpx 60rpx;
  box-sizing: border-box;
  background: #070d1b;
}
.card {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(34, 211, 238, 0.1);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

/* 不完整警示条 */
.incomplete-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: rgba(245, 158, 11, 0.08);
  border: 1rpx solid rgba(245, 158, 11, 0.25);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
}
.incomplete-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}
.incomplete-text {
  font-size: 26rpx;
  color: #f59e0b;
  line-height: 1.5;
  letter-spacing: 0.5rpx;
}

/* 头像卡 */
.avatar-card {
  display: flex;
  justify-content: center;
  padding: 48rpx 0;
}
.avatar-picker-btn {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
}
.avatar-picker-btn::after { border: none; }
.avatar-wrap {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}
.avatar-preview {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(34, 211, 238, 0.4);
  box-shadow: 0 0 24rpx rgba(34, 211, 238, 0.15);
}
.avatar-camera-overlay {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}
.avatar-camera-icon {
  font-size: 44rpx;
  line-height: 1;
}
.avatar-camera-text {
  font-size: 20rpx;
  color: #e2e8f0;
  letter-spacing: 1rpx;
}

/* 昵称输入卡 */
.input-card {
  padding: 0 32rpx;
}
.input-label {
  font-size: 24rpx;
  color: #475569;
  padding-top: 28rpx;
  padding-bottom: 8rpx;
  letter-spacing: 1rpx;
}
.nickname-input {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
  color: #e2e8f0;
  border-bottom: 1rpx solid rgba(34, 211, 238, 0.1);
  box-sizing: border-box;
  padding-bottom: 16rpx;
}
.input-placeholder { color: #334155; }

/* 保存按钮 */
.save-btn {
  margin-top: 16rpx;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #0a0f1a;
  background: linear-gradient(135deg, #0ea5e9, #22d3ee);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(34, 211, 238, 0.3);
  letter-spacing: 2rpx;
}
.save-btn.saving { opacity: 0.6; }
