<!-- 授权模式 / 申请模式：全屏引导 -->
<view wx:if="{{authMode || applyMode}}" class="auth-screen">

  <view class="auth-hero">
    <view class="auth-hero-emoji">🏃</view>
    <view class="auth-hero-title">{{applyMode ? '申请加入跑团' : '让队友认识你'}}</view>
    <view class="auth-hero-sub">{{applyMode ? '请使用你的微信昵称，方便管理员认出你' : '设置头像和昵称，才能出现在群周榜上'}}</view>
  </view>

  <view class="auth-form">
    <button class="auth-avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <view class="auth-avatar-wrap">
        <image class="auth-avatar" src="{{previewUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
        <view class="auth-avatar-overlay {{previewUrl ? 'set' : ''}}">
          <text class="auth-avatar-camera">{{previewUrl ? '✓' : '📷'}}</text>
        </view>
      </view>
      <view class="auth-avatar-label {{previewUrl ? 'done' : ''}}">
        {{previewUrl ? '头像已设置 ✓' : '点击设置头像'}}
      </view>
    </button>

    <view class="auth-nickname-field">
      <view class="auth-field-label">昵称<text class="auth-required">必填</text></view>
      <view wx:if="{{applyMode}}" class="auth-field-hint">请使用你的微信昵称，管理员依此认出你</view>
      <view class="auth-nickname-wrap {{nickname ? 'filled' : ''}}">
        <input
          class="auth-nickname-input"
          type="nickname"
          placeholder="点击填写，可直接使用微信昵称"
          placeholder-class="auth-nickname-placeholder"
          value="{{nickname}}"
          bindinput="onNicknameInput"
          confirm-type="done"
          maxlength="30"
        />
        <view wx:if="{{nickname}}" class="auth-nickname-check">✓</view>
      </view>
    </view>
  </view>

  <view class="auth-bottom">
    <view class="auth-social-tip">{{applyMode ? '⏳ 管理员审核通过后即可参与打卡' : '🏆 头像和昵称会显示在群周榜'}}</view>
    <view class="auth-allow-btn {{saving ? 'saving' : ''}} {{applyMode && !canSubmit ? 'disabled' : ''}}" bindtap="save">
      {{saving ? (applyMode ? '提交中...' : '保存中...') : (applyMode ? '提交加入申请 →' : '完成设置，进入跑团 →')}}
    </view>
    <view wx:if="{{applyMode && !canSubmit}}" class="apply-hint">请先设置头像，并填写昵称（至少 2 个字）</view>
    <view wx:if="{{!applyMode}}" class="auth-skip-btn" bindtap="skip">先跳过，榜单上显示为「匿名」</view>
  </view>

</view>

<!-- 普通编辑模式 -->
<view wx:else class="container">

  <notice-bar/>

  <!-- 资料不完整警示 -->
  <view wx:if="{{!previewUrl || !nickname}}" class="incomplete-banner">
    <text class="incomplete-icon">⚠️</text>
    <text class="incomplete-text">完善头像和昵称，才能在周榜上被队友认出</text>
  </view>

  <view class="card avatar-card">
    <button class="avatar-picker-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <view class="avatar-wrap">
        <image class="avatar-preview" src="{{previewUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
        <view class="avatar-camera-overlay">
          <text class="avatar-camera-icon">📷</text>
          <text class="avatar-camera-text">更换头像</text>
        </view>
      </view>
    </button>
  </view>

  <view class="card input-card">
    <view class="input-label">昵称</view>
    <input
      class="nickname-input"
      type="nickname"
      placeholder="点击填写，可直接使用微信昵称"
      placeholder-class="input-placeholder"
      value="{{nickname}}"
      bindinput="onNicknameInput"
      confirm-type="done"
      maxlength="30"
    />
  </view>

  <view class="save-btn {{saving ? 'saving' : ''}}" bindtap="save">
    {{saving ? '保存中...' : '保存资料'}}
  </view>

</view>
