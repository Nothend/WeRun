<view class="page">

  <notice-bar/>

  <!-- 顶部标签栏 -->
  <view class="tabs">
    <view wx:for="{{boards}}" wx:key="key"
          class="tab {{current === index ? 'tab-active' : ''}}"
          data-index="{{index}}" bindtap="onTapTab">
      {{item.label}}
    </view>
  </view>

  <!-- 榜单滑动区 -->
  <swiper wx:if="{{boards.length}}" class="boards"
          style="height: {{swiperHeight ? swiperHeight + 'px' : '80vh'}}"
          current="{{current}}" bindchange="onSwiperChange">
    <swiper-item wx:for="{{boards}}" wx:key="key" wx:for-item="board" wx:for-index="bIdx">
      <scroll-view scroll-y class="board-scroll">
        <!-- 前三名奖牌 -->
        <view class="podium" wx:if="{{board.top3.length}}">
          <!-- 第二名 -->
          <view class="podium-slot slot-2" wx:if="{{board.top3[1]}}">
            <image class="podium-avatar avatar-2 {{board.top3[1].isSponsor ? 'sponsor-avatar' : ''}}" src="{{board.top3[1].avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" data-openid="{{board.top3[1].openid}}" catchtap="goUser"/>
            <text class="podium-medal">🥈</text>
            <view class="podium-name {{board.top3[1].isSponsor ? 'sponsor-name' : ''}}">{{board.top3[1].nickname}}</view>
            <view wx:if="{{board.top3[1].isSponsor && board.top3[1].sponsorBadge}}" class="sponsor-badge podium-badge">{{board.top3[1].sponsorBadge}}</view>
            <view class="podium-count {{board.top3[1].achieved ? 'achieved' : ''}}">{{board.top3[1].count}} 次</view>
          </view>
          <!-- 第一名 -->
          <view class="podium-slot slot-1" wx:if="{{board.top3[0]}}">
            <text class="crown">👑</text>
            <image class="podium-avatar avatar-1 {{board.top3[0].isSponsor ? 'sponsor-avatar' : ''}}" src="{{board.top3[0].avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" data-openid="{{board.top3[0].openid}}" catchtap="goUser"/>
            <text class="podium-medal">🥇</text>
            <view class="podium-name {{board.top3[0].isSponsor ? 'sponsor-name' : ''}}">{{board.top3[0].nickname}}</view>
            <view wx:if="{{board.top3[0].isSponsor && board.top3[0].sponsorBadge}}" class="sponsor-badge podium-badge">{{board.top3[0].sponsorBadge}}</view>
            <view class="podium-count {{board.top3[0].achieved ? 'achieved' : ''}}">{{board.top3[0].count}} 次</view>
          </view>
          <!-- 第三名 -->
          <view class="podium-slot slot-3" wx:if="{{board.top3[2]}}">
            <image class="podium-avatar avatar-3 {{board.top3[2].isSponsor ? 'sponsor-avatar' : ''}}" src="{{board.top3[2].avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" data-openid="{{board.top3[2].openid}}" catchtap="goUser"/>
            <text class="podium-medal">🥉</text>
            <view class="podium-name {{board.top3[2].isSponsor ? 'sponsor-name' : ''}}">{{board.top3[2].nickname}}</view>
            <view wx:if="{{board.top3[2].isSponsor && board.top3[2].sponsorBadge}}" class="sponsor-badge podium-badge">{{board.top3[2].sponsorBadge}}</view>
            <view class="podium-count {{board.top3[2].achieved ? 'achieved' : ''}}">{{board.top3[2].count}} 次</view>
          </view>
        </view>

        <!-- 第四名起列表 -->
        <view class="list-card" wx:if="{{board.rest.length}}">
          <view wx:for="{{board.visibleRest}}" wx:key="openid" wx:for-item="row" class="row">
            <view class="rank-num">{{row.rank}}</view>
            <image class="avatar {{row.isSponsor ? 'sponsor-avatar' : ''}}" src="{{row.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill" data-openid="{{row.openid}}" catchtap="goUser"/>
            <view class="name {{row.isSponsor ? 'sponsor-name' : ''}}">{{row.nickname}}</view>
            <view wx:if="{{row.isSponsor && row.sponsorBadge}}" class="sponsor-badge">{{row.sponsorBadge}}</view>
            <view class="count-cell">
              <text class="count {{row.achieved ? 'achieved' : ''}}">{{row.count}}</text>
              <text class="count-unit muted">次</text>
              <view wx:if="{{row.achieved}}" class="badge">达标</view>
            </view>
          </view>

          <!-- 分页器 -->
          <view class="pager" wx:if="{{board.totalPages > 1}}">
            <view class="pager-btn {{board.page === 0 ? 'disabled' : ''}}"
                  data-index="{{bIdx}}" bindtap="onPrevPage">上一页</view>
            <text class="pager-info">{{board.page + 1}} / {{board.totalPages}}</text>
            <view class="pager-btn {{board.page >= board.totalPages - 1 ? 'disabled' : ''}}"
                  data-index="{{bIdx}}" bindtap="onNextPage">下一页</view>
          </view>
        </view>

        <!-- 空态 -->
        <view wx:if="{{board.total === 0}}" class="empty">本榜暂无数据，快去打卡吧～</view>

        <!-- 管理员：生成金主报告海报（本周/本月/本年榜显示对应周期） -->
        <view wx:if="{{isAdmin && board.reportPeriod}}"
              class="share-group-btn report-btn {{reportLoading === board.reportPeriod ? 'btn-loading' : ''}}"
              data-period="{{board.reportPeriod}}"
              bindtap="genReport">
          {{reportLoading === board.reportPeriod ? '生成中…' : '🏆 生成金主报告'}}
        </view>

        <view class="scroll-bottom"></view>
      </scroll-view>
    </swiper-item>
  </swiper>

  <view wx:if="{{loading}}" class="loading muted">加载中...</view>
</view>
