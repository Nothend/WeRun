<view class="container">
  <!-- 本周概览 -->
  <view wx:if="{{data}}" class="card summary-card">
    <view class="week-label">{{data.weekKey}}</view>
    <view class="summary-row">
      <view class="summary-item">
        <text class="summary-num">{{data.achievedCount}}</text>
        <text class="summary-sub">已达标</text>
      </view>
      <view class="summary-sep"></view>
      <view class="summary-item">
        <text class="summary-num">{{data.total}}</text>
        <text class="summary-sub">总人数</text>
      </view>
      <view class="summary-sep"></view>
      <view class="summary-item">
        <text class="summary-num">≥ {{data.target}}</text>
        <text class="summary-sub">达标次数</text>
      </view>
    </view>
  </view>

  <!-- 排行榜 -->
  <view wx:if="{{data}}" class="card list-card">
    <view wx:for="{{data.list}}" wx:key="openid"
          class="row {{index < 3 ? 'top-row' : ''}}">
      <view class="rank-cell">
        <text wx:if="{{index === 0}}" class="medal">🥇</text>
        <text wx:elif="{{index === 1}}" class="medal">🥈</text>
        <text wx:elif="{{index === 2}}" class="medal">🥉</text>
        <text wx:else class="rank-num">{{index + 1}}</text>
      </view>
      <image class="avatar" src="{{item.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
      <view class="name">{{item.nickname || '未设昵称'}}</view>
      <view class="count-cell">
        <text class="count {{item.achieved ? 'achieved' : ''}}">{{item.weekCount}}</text>
        <text class="count-unit muted">次</text>
        <view wx:if="{{item.achieved}}" class="badge">达标</view>
      </view>
    </view>
    <view wx:if="{{data.list.length === 0}}" class="empty">
      还没有成员，快去打卡吧～
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading muted">加载中...</view>
</view>
