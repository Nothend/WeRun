.summary {
  text-align: center;
}
.week {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.row:last-child {
  border-bottom: none;
}
.rank {
  width: 48rpx;
  text-align: center;
  color: #999;
  font-size: 30rpx;
}
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  margin: 0 20rpx;
}
.name {
  flex: 1;
  font-size: 30rpx;
}
.count {
  font-size: 30rpx;
  color: #666;
}
.count.ok {
  color: #07c160;
  font-weight: 600;
}
.badge {
  display: inline-block;
  font-size: 22rpx;
  color: #fff;
  background: #07c160;
  border-radius: 8rpx;
  padding: 2rpx 10rpx;
  margin-left: 8rpx;
}
.empty {
  text-align: center;
  padding: 40rpx 0;
}
