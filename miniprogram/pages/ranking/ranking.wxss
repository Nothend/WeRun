/* ── 页面 ── */
/* 整页固定为一屏高度、禁止整页滚动：只保留榜单内 scroll-view 这一层纵向滚动，
   避免「外层页面 + 内层榜单」两层滚动相互误判（外层会把滚动公告顶出屏幕） */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ── 顶部标签栏 ── */
.tabs {
  display: flex;
  height: 96rpx;
  align-items: stretch;
  background: #ffffff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
  position: sticky;
  top: 0;
  z-index: 10;
}
.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #8a9099;
  position: relative;
  letter-spacing: 1rpx;
}
.tab-active {
  color: #07c160;
  font-weight: 600;
}
.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #07c160;
}

/* ── 榜单滑动区 ── */
.boards {
  width: 100%;
}
.board-scroll {
  height: 100%;
  box-sizing: border-box;
}

/* ── 前三名领奖台 ── */
.podium {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 24rpx;
  padding: 56rpx 32rpx 40rpx;
}
.podium-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  max-width: 200rpx;
  position: relative;
}
.slot-1 {
  order: 2;
  transform: translateY(-20rpx);
}
.slot-2 {
  order: 1;
}
.slot-3 {
  order: 3;
}
.crown {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}
.podium-avatar {
  border-radius: 50%;
  background: #eef1f5;
  border: 3rpx solid rgba(0, 0, 0, 0.06);
}
.avatar-1 {
  width: 132rpx;
  height: 132rpx;
  border-color: #f0b400;
}
.avatar-2 {
  width: 108rpx;
  height: 108rpx;
  border-color: #aab2bd;
}
.avatar-3 {
  width: 108rpx;
  height: 108rpx;
  border-color: #cd7f32;
}
.podium-medal {
  font-size: 40rpx;
  line-height: 1;
  margin-top: -24rpx;
  margin-bottom: 8rpx;
}
.podium-name {
  font-size: 26rpx;
  color: #1a1a1a;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}
.podium-badge {
  margin-left: 0;
  margin-top: 8rpx;
}
.podium-count {
  font-size: 24rpx;
  font-weight: 700;
  color: #8a9099;
  margin-top: 6rpx;
}
.podium-count.achieved {
  color: #07c160;
}

/* ── 第四名起列表 ── */
.list-card {
  margin: 0 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 20rpx;
  overflow: hidden;
}
.row {
  display: flex;
  align-items: center;
  padding: 22rpx 28rpx;
}
.row + .row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.rank-num {
  width: 52rpx;
  text-align: center;
  flex-shrink: 0;
  margin-right: 12rpx;
  font-size: 26rpx;
  color: #8a9099;
  font-weight: 600;
}
.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #eef1f5;
  margin-right: 18rpx;
  flex-shrink: 0;
}
.name {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}
.count-cell {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}
.count {
  font-size: 32rpx;
  font-weight: 700;
  color: #c0c5cc;
}
.count.achieved {
  color: #07c160;
}
.count-unit {
  font-size: 22rpx;
  margin-top: 4rpx;
}
.badge {
  margin-left: 10rpx;
  font-size: 20rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  border: 1rpx solid rgba(7, 193, 96, 0.25);
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
}

/* ── 分页器 ── */
.pager {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  padding: 28rpx 0;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.pager-btn {
  font-size: 24rpx;
  color: #07c160;
  padding: 10rpx 28rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.3);
  border-radius: 12rpx;
  background: rgba(7, 193, 96, 0.08);
}
.pager-btn.disabled {
  color: #c0c5cc;
  border-color: rgba(0, 0, 0, 0.06);
  background: transparent;
}
.pager-info {
  font-size: 24rpx;
  color: #8a9099;
  letter-spacing: 1rpx;
}

/* ── 空态 / 加载 ── */
.empty {
  text-align: center;
  padding: 96rpx 0;
  color: #aab0b8;
  font-size: 26rpx;
}
.loading {
  text-align: center;
  padding: 48rpx 0;
}
/* 底部占位：撑出整条自定义 tabBar 的高度（含安全区）再加 24rpx 自然空隙，
   保证滚到底时「生成金主报告」按钮完整露在 tabBar 上方 */
.scroll-bottom {
  height: calc(var(--tabbar-h) + 24rpx);
}

/* ── 生成金主报告按钮（金色调）── */
.report-btn {
  margin: 16rpx 24rpx 0;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 26rpx;
  color: #c8902a;
  background: rgba(245, 197, 66, 0.1);
  border: 1rpx solid rgba(245, 197, 66, 0.3);
  border-radius: 14rpx;
  letter-spacing: 1rpx;
}
.report-btn.btn-loading {
  color: #aab0b8;
}

