/* ── 概览卡 ── */
.summary-card {
  text-align: center;
  padding: 40rpx;
}
.week-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #22d3ee;
  letter-spacing: 3rpx;
  margin-bottom: 32rpx;
}
.summary-row {
  display: flex;
  align-items: center;
  justify-content: center;
}
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.summary-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #e2e8f0;
  letter-spacing: -1rpx;
}
.summary-sub {
  font-size: 22rpx;
  color: #334155;
  letter-spacing: 1rpx;
}
.summary-sep {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.06);
  margin: 0 8rpx;
}

/* ── 列表卡 ── */
.list-card {
  padding: 0;
  overflow: hidden;
}
.row {
  display: flex;
  align-items: center;
  padding: 24rpx 40rpx;
}
.row + .row {
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.top-row {
  background: rgba(34, 211, 238, 0.02);
}
.rank-cell {
  width: 60rpx;
  text-align: center;
  flex-shrink: 0;
  margin-right: 12rpx;
}
.medal {
  font-size: 36rpx;
  line-height: 1;
}
.rank-num {
  font-size: 26rpx;
  color: #2d3e56;
  font-weight: 600;
}
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #1a2942;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.name {
  flex: 1;
  font-size: 28rpx;
  color: #cbd5e1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}
.count-cell {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
}
.count {
  font-size: 34rpx;
  font-weight: 700;
  color: #2d3e56;
}
.count.achieved {
  color: #4ade80;
}
.count-unit {
  font-size: 22rpx;
  margin-top: 4rpx;
}
.badge {
  margin-left: 10rpx;
  font-size: 20rpx;
  color: #4ade80;
  background: rgba(74, 222, 128, 0.1);
  border: 1rpx solid rgba(74, 222, 128, 0.25);
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
}
.empty {
  text-align: center;
  padding: 72rpx 0;
  color: #2d3e56;
  font-size: 26rpx;
}
.loading {
  text-align: center;
  padding: 48rpx 0;
}

/* ── 分享群总览按钮 ── */
.share-group-btn {
  margin-top: 32rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 26rpx;
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.07);
  border: 1rpx solid rgba(34, 211, 238, 0.2);
  border-radius: 14rpx;
  letter-spacing: 1rpx;
}
.share-group-btn.btn-loading {
  color: #334155;
}

/* ── 分享弹窗 ── */
.share-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.share-modal {
  background: #0f1e33;
  border: 1rpx solid rgba(34, 211, 238, 0.2);
  border-radius: 28rpx;
  padding: 48rpx 44rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 600rpx;
}
.share-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e2e8f0;
  margin-bottom: 32rpx;
  letter-spacing: 1rpx;
}
.share-text-box {
  width: 100%;
  background: rgba(34, 211, 238, 0.04);
  border: 1rpx solid rgba(34, 211, 238, 0.12);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 32rpx;
  min-height: 120rpx;
}
.share-text {
  font-size: 28rpx;
  color: #cbd5e1;
  line-height: 1.7;
}
.share-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
  margin-bottom: 28rpx;
}
.share-copy-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.08);
  border: 1rpx solid rgba(34, 211, 238, 0.25);
  border-radius: 16rpx;
}
.share-forward-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #0ea5e9, #22d3ee);
  border-radius: 16rpx;
  border: none;
  padding: 0;
  margin: 0;
  box-shadow: 0 4rpx 16rpx rgba(34, 211, 238, 0.25);
}
.share-forward-btn::after {
  border: none;
}
.share-close {
  font-size: 26rpx;
  color: #475569;
  padding: 12rpx 48rpx;
  border: 1rpx solid rgba(71, 85, 105, 0.2);
  border-radius: 12rpx;
}
