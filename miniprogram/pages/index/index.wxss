/* ── 登录页 ── */
.login-screen {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx 120rpx;
  text-align: center;
}
.login-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 32rpx;
}
.login-title {
  font-size: 64rpx;
  font-weight: 800;
  color: #e2e8f0;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}
.login-desc {
  font-size: 26rpx;
  color: #475569;
  letter-spacing: 3rpx;
  margin-bottom: 80rpx;
}
.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

/* ── 资料卡 ── */
.profile-card {
  padding: 36rpx 40rpx 32rpx;
}
.profile-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 32rpx;
}
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid rgba(34, 211, 238, 0.3);
  box-shadow: 0 0 16rpx rgba(34, 211, 238, 0.1);
}
.profile-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.profile-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #e2e8f0;
  letter-spacing: 0.5rpx;
}
.profile-sub {
  font-size: 22rpx;
  color: #475569;
  letter-spacing: 1rpx;
}
.profile-stats {
  display: flex;
  align-items: center;
  background: rgba(34, 211, 238, 0.04);
  border: 1rpx solid rgba(34, 211, 238, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 0;
}
.pstat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.pstat-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #22d3ee;
  line-height: 1;
  letter-spacing: -1rpx;
}
.pstat-label {
  font-size: 20rpx;
  color: #475569;
  letter-spacing: 2rpx;
}
.pstat-divider {
  width: 1rpx;
  height: 64rpx;
  background: rgba(34, 211, 238, 0.12);
}

/* ── 上传截图打卡 ── */
.checkin-card {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
}
.card-hover {
  background: rgba(34, 211, 238, 0.06);
}
.checkin-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(34, 211, 238, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}
.checkin-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.checkin-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #e2e8f0;
}
.checkin-sub {
  font-size: 22rpx;
  color: #475569;
  letter-spacing: 0.5rpx;
}

/* ── 快速入口 ── */
.actions-card {
  padding: 0;
  overflow: hidden;
}
.action-item {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
}
.action-item + .action-item {
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.action-hover {
  background: rgba(34, 211, 238, 0.04);
}
.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.action-item.primary .action-icon-wrap {
  background: rgba(34, 211, 238, 0.1);
}
.action-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #cbd5e1;
}
.action-item.primary .action-text {
  color: #e2e8f0;
}
.logout-text {
  color: #ef4444;
}
.action-chevron {
  font-size: 48rpx;
  color: #1e3050;
  font-weight: 300;
  line-height: 1;
}

/* ── 分享运动数据 ── */
.share-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.share-modal {
  background: #0f1e33;
  border: 1rpx solid rgba(34, 211, 238, 0.2);
  border-radius: 28rpx;
  padding: 48rpx 44rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 600rpx;
}
.share-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e2e8f0;
  margin-bottom: 32rpx;
  letter-spacing: 1rpx;
}
.share-text-box {
  width: 100%;
  background: rgba(34, 211, 238, 0.04);
  border: 1rpx solid rgba(34, 211, 238, 0.12);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 32rpx;
  min-height: 120rpx;
}
.share-text {
  font-size: 28rpx;
  color: #cbd5e1;
  line-height: 1.7;
  letter-spacing: 0.5rpx;
}
.share-actions {
  display: flex;
  gap: 20rpx;
  width: 100%;
  margin-bottom: 28rpx;
}
.share-copy-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.08);
  border: 1rpx solid rgba(34, 211, 238, 0.25);
  border-radius: 16rpx;
}
.share-forward-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #0ea5e9, #22d3ee);
  border-radius: 16rpx;
  border: none;
  padding: 0;
  margin: 0;
  box-shadow: 0 4rpx 16rpx rgba(34, 211, 238, 0.25);
}
.share-forward-btn::after {
  border: none;
}
.share-close {
  font-size: 26rpx;
  color: #475569;
  padding: 12rpx 48rpx;
  border: 1rpx solid rgba(71, 85, 105, 0.2);
  border-radius: 12rpx;
}


