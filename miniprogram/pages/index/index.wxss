/* ── 滚动公告 ── */
.notice-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
  background: rgba(7, 193, 96, 0.08);
  border: 2rpx solid rgba(7, 193, 96, 0.18);
  border-radius: 16rpx;
}
.notice-icon {
  flex-shrink: 0;
  font-size: 26rpx;
}
.notice-viewport {
  flex: 1;
  overflow: hidden;
}
.notice-track {
  display: inline-block;
  white-space: nowrap;
  font-size: 24rpx;
  color: #1a8d4e;
  letter-spacing: 0.5rpx;
  padding-left: 100%;
  animation: notice-marquee 12s linear infinite;
}
@keyframes notice-marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-100%); }
}

/* ── 资料卡 ── */
.profile-card {
  padding: 36rpx 40rpx 32rpx;
}
.profile-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 32rpx;
}
.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid rgba(7, 193, 96, 0.3);
  box-shadow: 0 0 16rpx rgba(7, 193, 96, 0.12);
}
.profile-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.profile-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}
.profile-sub {
  font-size: 22rpx;
  color: #8a9099;
  letter-spacing: 1rpx;
}
.profile-login-badge {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: #07c160;
  padding: 12rpx 28rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.3);
  border-radius: 100rpx;
}
.profile-stats {
  display: flex;
  align-items: center;
  background: rgba(7, 193, 96, 0.05);
  border: 1rpx solid rgba(7, 193, 96, 0.12);
  border-radius: 16rpx;
  padding: 24rpx 0;
}
.pstat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.pstat-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #07c160;
  line-height: 1;
  letter-spacing: -1rpx;
}
.pstat-label {
  font-size: 20rpx;
  color: #8a9099;
  letter-spacing: 2rpx;
}
.pstat-divider {
  width: 1rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.08);
}
.pstat-hover {
  opacity: 0.6;
}
.today-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding: 14rpx 24rpx;
  background: rgba(7, 193, 96, 0.08);
  border: 1rpx solid rgba(7, 193, 96, 0.2);
  border-radius: 12rpx;
}
.today-label {
  font-size: 24rpx;
  color: #07c160;
}
.today-del {
  font-size: 22rpx;
  color: #fa5151;
  padding: 6rpx 20rpx;
  border: 1rpx solid rgba(250, 81, 81, 0.3);
  border-radius: 8rpx;
}

/* ── 上传截图打卡 ── */
.checkin-card {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
}
.card-hover {
  background: rgba(7, 193, 96, 0.06);
}
.checkin-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(7, 193, 96, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 28rpx;
  flex-shrink: 0;
}
.checkin-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.checkin-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.checkin-sub {
  font-size: 22rpx;
  color: #8a9099;
  letter-spacing: 0.5rpx;
}

/* ── 今日打卡动态 ── */
.feed-card {
  padding: 32rpx 36rpx;
}
.feed-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.feed-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}
.feed-count {
  font-size: 22rpx;
  color: #07c160;
  font-weight: 600;
}
.feed-list {
  display: flex;
  flex-direction: column;
}
.feed-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 0;
  animation: feed-fade 0.4s ease both;
}
.feed-item + .feed-item {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.feed-item-hover {
  opacity: 0.55;
}
@keyframes feed-fade {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.feed-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  border: 2rpx solid rgba(7, 193, 96, 0.25);
}
.feed-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.feed-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.feed-desc {
  font-size: 24rpx;
  color: #07c160;
}
.feed-time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #b0b6bf;
}
.feed-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 36rpx 0 24rpx;
}
.feed-empty-icon {
  font-size: 56rpx;
}
.feed-empty-text {
  font-size: 24rpx;
  color: #8a9099;
  letter-spacing: 0.5rpx;
}

/* ── 快速入口 ── */
.actions-card {
  padding: 0;
  overflow: hidden;
}
.action-item {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
}
.action-item + .action-item {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.action-hover {
  background: rgba(7, 193, 96, 0.05);
}
.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: #f5f7fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.action-item.primary .action-icon-wrap {
  background: rgba(7, 193, 96, 0.12);
}
.action-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #3d4350;
}
.action-item.primary .action-text {
  color: #1a1a1a;
}
.logout-text {
  color: #fa5151;
}
.action-chevron {
  font-size: 48rpx;
  color: #c5cbd3;
  font-weight: 300;
  line-height: 1;
}

/* ── 待审核申请提示卡 ── */
.pending-banner {
  padding: 32rpx 36rpx;
  border-color: rgba(234, 179, 8, 0.4);
  background: rgba(234, 179, 8, 0.08);
}
.pending-banner-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.pending-banner-icon {
  font-size: 36rpx;
}
.pending-banner-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #d48806;
  letter-spacing: 0.5rpx;
}
.pending-banner-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.pending-banner-msg {
  font-size: 26rpx;
  color: #5a6270;
  line-height: 1.6;
}
.pending-banner-btn {
  align-self: flex-start;
  font-size: 26rpx;
  font-weight: 600;
  color: #d48806;
  padding: 14rpx 32rpx;
  border: 1rpx solid rgba(234, 179, 8, 0.5);
  border-radius: 100rpx;
}
.pending-banner-edit {
  align-self: flex-start;
  font-size: 24rpx;
  color: #8a9099;
  padding: 10rpx 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.12);
  border-radius: 100rpx;
}
.pending-banner-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.pending-banner-actions .pending-banner-btn,
.pending-banner-actions .pending-banner-edit {
  align-self: auto;
}
