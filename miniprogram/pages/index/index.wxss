/* ── 登录页 ── */
.login-screen {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx 120rpx;
  text-align: center;
}
.login-icon {
  font-size: 120rpx;
  line-height: 1;
  margin-bottom: 32rpx;
}
.login-title {
  font-size: 64rpx;
  font-weight: 800;
  color: #e2e8f0;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}
.login-desc {
  font-size: 26rpx;
  color: #475569;
  letter-spacing: 3rpx;
  margin-bottom: 80rpx;
}
.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

/* ── 资料卡 ── */
.profile-card {
  padding: 32rpx 40rpx;
}
.profile-row {
  display: flex;
  align-items: flex-start;
  gap: 32rpx;
}
.avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}
.avatar-btn {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  overflow: hidden;
  padding: 0;
  margin: 0;
  background: #1a2942;
  line-height: 0;
  border: 2rpx solid rgba(34, 211, 238, 0.3) !important;
  box-shadow: 0 0 16rpx rgba(34, 211, 238, 0.1);
}
.avatar-btn::after {
  border: none;
}
.avatar {
  width: 104rpx;
  height: 104rpx;
  display: block;
}
.avatar-hint {
  font-size: 20rpx;
  color: #22d3ee;
  margin-top: 10rpx;
  letter-spacing: 1rpx;
}
.profile-fields {
  flex: 1;
  min-width: 0;
  padding-top: 8rpx;
}
.nickname-input {
  width: 100%;
  font-size: 30rpx;
  color: #e2e8f0;
  border-bottom: 1rpx solid rgba(34, 211, 238, 0.15);
  padding-bottom: 14rpx;
  margin-bottom: 16rpx;
}
.input-ph {
  color: #2d3e56;
  font-size: 30rpx;
}
.profile-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.btn-save {
  font-size: 22rpx;
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.08);
  border: 1rpx solid rgba(34, 211, 238, 0.25) !important;
  border-radius: 10rpx;
  padding: 0 22rpx;
  height: 52rpx;
  line-height: 52rpx;
  margin: 0;
}
.btn-save::after {
  border: none;
}

/* ── 本周打卡 ── */
.stats-card {
  text-align: center;
  padding: 48rpx 40rpx 40rpx;
}
.stats-header {
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  color: #334155;
  text-transform: uppercase;
  margin-bottom: 28rpx;
}
.stats-nums {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  line-height: 1;
  margin-bottom: 32rpx;
}
.stats-num {
  font-size: 100rpx;
  font-weight: 800;
  color: #22d3ee;
  letter-spacing: -4rpx;
  line-height: 1;
}
.stats-denom {
  font-size: 36rpx;
  color: #334155;
  margin-bottom: 14rpx;
  margin-left: 6rpx;
}
.progress-track {
  height: 6rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0ea5e9, #22d3ee);
  border-radius: 4rpx;
  box-shadow: 0 0 10rpx rgba(34, 211, 238, 0.7);
}
.stats-status {
  font-size: 26rpx;
  color: #475569;
}
/* 达标态 */
.stats-card.achieved .stats-num {
  color: #4ade80;
}
.stats-card.achieved .progress-fill {
  background: linear-gradient(90deg, #22c55e, #4ade80);
  box-shadow: 0 0 10rpx rgba(74, 222, 128, 0.7);
}
.stats-card.achieved .stats-status {
  color: #4ade80;
}

/* ── 快速入口 ── */
.actions-card {
  padding: 0;
  overflow: hidden;
}
.action-item {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
}
.action-item + .action-item {
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.action-hover {
  background: rgba(34, 211, 238, 0.04);
}
.action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.action-item.primary .action-icon-wrap {
  background: rgba(34, 211, 238, 0.1);
}
.action-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #cbd5e1;
}
.action-item.primary .action-text {
  color: #e2e8f0;
}
.action-chevron {
  font-size: 48rpx;
  color: #1e3050;
  font-weight: 300;
  line-height: 1;
}
