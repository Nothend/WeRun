/* ── 主角：打卡 Hero ── */
.hero {
  display: flex;
  align-items: center;
  gap: 28rpx;
  background: var(--surface);
  border-radius: var(--r-lg);
  padding: 44rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}
.hero-hover {
  background: #fafbfc;
}
.hero-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  background: var(--brand-soft);
  color: var(--brand);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.hero-icon .icon {
  font-size: 52rpx;
}
.hero-icon.done {
  background: var(--brand);
  color: #fff;
}
.hero-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}
.hero-title {
  font-size: var(--fs-h1);
  font-weight: 700;
  color: var(--text-1);
  letter-spacing: 0.5rpx;
}
.hero-sub {
  font-size: var(--fs-meta);
  color: var(--text-2);
  line-height: 1.5;
}
.hero-chevron {
  font-size: 40rpx;
  color: var(--text-3);
}
.hero-undo {
  flex-shrink: 0;
  font-size: var(--fs-meta);
  color: var(--danger);
  padding: 12rpx 28rpx;
  border: 1rpx solid rgba(250, 81, 81, 0.25);
  border-radius: var(--r-pill);
}

/* ── 本周进度速览 ── */
.progress-card {
  display: flex;
  align-items: center;
  background: var(--surface);
  border-radius: var(--r-lg);
  padding: 40rpx 0;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}
.progress-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}
.progress-hover {
  opacity: 0.55;
}
.progress-num {
  font-size: var(--fs-hero);
  font-weight: 800;
  color: var(--text-1);
  line-height: 1;
  letter-spacing: -1rpx;
}
.progress-num.achieved {
  color: var(--brand);
}
.progress-label {
  font-size: var(--fs-cap);
  color: var(--text-3);
  letter-spacing: 0.5rpx;
}
.progress-divider {
  width: 1rpx;
  height: 72rpx;
  background: var(--hairline);
}

/* ── 今日动态 ── */
.feed-card {
  padding: 32rpx 32rpx 12rpx;
}
.feed-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.feed-count {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--fs-cap);
  color: var(--brand);
  font-weight: 600;
}
.feed-count-icon {
  font-size: 26rpx;
}
.feed-list {
  display: flex;
  flex-direction: column;
}
.feed-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx 0;
  animation: feed-fade 0.4s ease both;
}
.feed-item + .feed-item {
  border-top: 1rpx solid var(--hairline);
}
.feed-item-hover {
  opacity: 0.55;
}
@keyframes feed-fade {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.feed-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #eef1f5;
}
.feed-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.feed-name {
  font-size: var(--fs-body);
  font-weight: 600;
  color: var(--text-1);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.feed-desc {
  font-size: var(--fs-meta);
  color: var(--text-2);
}
.feed-time {
  flex-shrink: 0;
  font-size: var(--fs-cap);
  color: var(--text-3);
}
.feed-empty {
  padding: 40rpx 0 36rpx;
  text-align: center;
}
.feed-empty-text {
  font-size: var(--fs-meta);
  color: var(--text-3);
}

/* ── 待审核 / 邀请加入卡 ── */
.pending-banner {
  padding: 36rpx;
  background: #fffaf0;
  box-shadow: none;
  border: 1rpx solid rgba(234, 179, 8, 0.25);
}
.pending-banner-top {
  margin-bottom: 16rpx;
}
.pending-banner-title {
  font-size: var(--fs-h2);
  font-weight: 700;
  color: #b78103;
  letter-spacing: 0.5rpx;
}
.pending-banner-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.pending-banner-msg {
  font-size: var(--fs-meta);
  color: var(--text-2);
  line-height: 1.6;
}
.pending-banner-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.pending-banner-btn {
  align-self: flex-start;
  font-size: var(--fs-meta);
  font-weight: 600;
  color: #b78103;
  padding: 14rpx 32rpx;
  border: 1rpx solid rgba(234, 179, 8, 0.4);
  border-radius: var(--r-pill);
}
.pending-banner-edit {
  font-size: var(--fs-cap);
  color: var(--text-2);
  padding: 12rpx 28rpx;
  border: 1rpx solid var(--hairline);
  border-radius: var(--r-pill);
}
.pending-banner-actions .pending-banner-btn {
  align-self: auto;
}
