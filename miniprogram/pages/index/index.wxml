<view class="container">

  <!-- 滚动公告（管理员后台设置，空则不显示） -->
  <notice-bar/>

  <!-- 已登录未申请：邀请加入卡 -->
  <view wx:if="{{isPending && !hasApplied}}" class="card pending-banner">
    <view class="pending-banner-top">
      <text class="pending-banner-title">加入跑团</text>
    </view>
    <view class="pending-banner-body">
      <view class="pending-banner-msg">填写昵称和头像提交加入申请，管理员通过后即可参与打卡和查看排行榜</view>
      <view class="pending-banner-btn" bindtap="goApply">提交加入申请</view>
    </view>
  </view>

  <!-- 已申请：待审核提示卡 -->
  <view wx:elif="{{isPending && hasApplied}}" class="card pending-banner">
    <view class="pending-banner-top">
      <text class="pending-banner-title">申请审核中</text>
    </view>
    <view class="pending-banner-body">
      <view class="pending-banner-msg">你的加入申请等待管理员审核，通过后即可参与打卡和查看排行榜</view>
      <view class="pending-banner-actions">
        <view class="pending-banner-btn" bindtap="onRefreshStatus">刷新审核状态</view>
        <view class="pending-banner-edit" bindtap="goApply">修改昵称</view>
      </view>
    </view>
  </view>

  <!-- ── 主角：打卡 ── -->
  <!-- 未登录 -->
  <view wx:if="{{!user}}" class="hero hero-cta" hover-class="hero-hover" hover-stay-time="120" bindtap="handleLogin">
    <view class="hero-icon"><text class="icon icon-camera"></text></view>
    <view class="hero-main">
      <text class="hero-title">{{loggingIn ? '登录中…' : '上传截图打卡'}}</text>
      <text class="hero-sub">微信登录后，上传运动截图自动核验时长</text>
    </view>
    <text class="icon icon-chevron hero-chevron"></text>
  </view>

  <!-- 已登录且通过：打卡卡（打卡行 + 本周/累计进度细条，合并为一张卡省空间） -->
  <view wx:elif="{{!isPending}}" class="hero-card">
    <!-- 今日已打卡 -->
    <view wx:if="{{stats && stats.todayCheckin}}" class="hero hero-flush hero-done">
      <view class="hero-icon done"><text class="icon icon-check"></text></view>
      <view class="hero-main">
        <text class="hero-title">今日已打卡</text>
        <text class="hero-sub">已记录约 {{stats.todayCheckin.duration}} 分钟，继续保持</text>
      </view>
      <text class="hero-undo" catchtap="deleteCheckinToday">撤销</text>
    </view>
    <!-- 去打卡 -->
    <view wx:else class="hero hero-flush hero-cta" hover-class="hero-hover" hover-stay-time="120" bindtap="goCheckin">
      <view class="hero-icon"><text class="icon icon-camera"></text></view>
      <view class="hero-main">
        <text class="hero-title">上传截图打卡</text>
        <text class="hero-sub">上传运动截图，自动核验时长 · ≥{{minDurationMinutes}} 分钟计一次</text>
      </view>
      <text class="icon icon-chevron hero-chevron"></text>
    </view>

    <!-- 进度细条：本周 / 累计，点击进打卡明细 -->
    <view class="hero-strip">
      <view class="hero-strip-item" hover-class="{{stats ? 'hero-strip-hover' : ''}}" hover-stay-time="150" data-scope="week" catchtap="openRecords">
        <text class="hero-strip-num {{stats && stats.weekCount >= weeklyTarget ? 'achieved' : ''}}">{{stats ? stats.weekCount : '-'}}</text>
        <text class="hero-strip-label">本周 · 目标 {{weeklyTarget}}</text>
      </view>
      <view class="hero-strip-divider"></view>
      <view class="hero-strip-item" hover-class="{{stats ? 'hero-strip-hover' : ''}}" hover-stay-time="150" data-scope="all" catchtap="openRecords">
        <text class="hero-strip-num">{{stats ? stats.totalCount : '-'}}</text>
        <text class="hero-strip-label">累计</text>
      </view>
    </view>
  </view>

  <!-- ── 未读战报（周/月/年报，读后消失）── -->
  <view wx:if="{{user && !isPending && reports.length}}" class="report-card">
    <view class="report-head">
      <view class="report-dot"></view>
      <text class="report-title">新战报</text>
      <text class="report-badge">{{reports.length}}</text>
    </view>
    <view wx:for="{{reports}}" wx:key="key" class="report-item" hover-class="report-item-hover" hover-stay-time="120"
          data-key="{{item.key}}" data-board="{{item.board}}" bindtap="openReport">
      <view class="report-item-main">
        <text class="report-item-label">{{item.label}}</text>
        <text class="report-item-text">{{item.text}}</text>
      </view>
      <text class="report-item-cta">看榜单</text>
      <text class="icon icon-chevron report-item-chevron"></text>
    </view>
  </view>

  <!-- ── 今日动态 ── -->
  <view wx:if="{{user && !isPending}}" class="card feed-card">
    <view class="feed-head">
      <text class="section-title">今日动态</text>
      <view wx:if="{{feed.length}}" class="feed-count">
        <text class="icon icon-flame feed-count-icon"></text>
        <text>{{feed.length}} 人在动</text>
      </view>
    </view>
    <view wx:if="{{feed.length}}" class="feed-list">
      <view wx:for="{{feed}}" wx:key="openid" class="feed-item" hover-class="feed-item-hover" hover-stay-time="150" data-openid="{{item.openid}}" bindtap="goUser">
        <image class="feed-avatar {{item.isSponsor ? 'sponsor-avatar' : ''}}" src="{{item.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
        <view class="feed-main">
          <view class="sponsor-nameline">
            <text class="feed-name {{item.isSponsor ? 'sponsor-name' : ''}}">{{item.nickname}}</text>
            <text wx:if="{{item.isSponsor && item.sponsorBadge}}" class="sponsor-badge">{{item.sponsorBadge}}</text>
          </view>
          <text class="feed-desc">打卡 {{item.duration}} 分钟</text>
        </view>
        <text class="feed-time">{{item.timeText}}</text>
      </view>
    </view>
    <view wx:elif="{{feedLoaded}}" class="feed-empty">
      <text class="feed-empty-text">今天还没有人打卡，来做第一个动起来的人</text>
    </view>
  </view>

</view>
