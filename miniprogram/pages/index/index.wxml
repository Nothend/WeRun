<!-- 未登录 -->
<view wx:if="{{!user}}" class="login-screen">
  <view class="login-icon">⚡</view>
  <view class="login-title">WeRun</view>
  <view class="login-desc">微信跑步群打卡</view>
  <button class="btn-primary login-btn" loading="{{loggingIn}}" bindtap="handleLogin">
    微信登录
  </button>
</view>

<!-- 已登录 -->
<view wx:if="{{user}}" class="container">

  <!-- 个人资料 -->
  <view class="card profile-card">
    <view class="profile-row" bindtap="openProfilePage">
      <image class="avatar" src="{{avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
      <view class="profile-info">
        <text class="profile-name">{{nickname || '未设置昵称'}}</text>
        <text class="profile-sub">跑团成员 · 点击编辑资料</text>
      </view>
    </view>
    <view class="profile-stats">
      <view class="pstat-item">
        <text class="pstat-num">{{stats ? stats.weekCount : '-'}}</text>
        <text class="pstat-label">本周打卡</text>
      </view>
      <view class="pstat-divider"></view>
      <view class="pstat-item">
        <text class="pstat-num">{{stats ? stats.totalCount : '-'}}</text>
        <text class="pstat-label">总打卡次数</text>
      </view>
    </view>
  </view>

  <!-- 上传截图打卡 -->
  <view class="card checkin-card" hover-class="card-hover" hover-stay-time="150" bindtap="goCheckin">
    <view class="checkin-icon-wrap">📷</view>
    <view class="checkin-content">
      <text class="checkin-title">上传截图打卡</text>
      <text class="checkin-sub">上传运动截图，AI 识别时长</text>
    </view>
    <text class="action-chevron">›</text>
  </view>

  <!-- 快速入口 -->
  <view class="card actions-card">
    <view class="action-item sponsor-item" hover-class="action-hover" hover-stay-time="150" bindtap="openSponsor">
      <view class="action-icon-wrap">☕</view>
      <text class="action-text sponsor-text">支持作者</text>
      <text class="action-chevron">›</text>
    </view>
    <view class="action-item" hover-class="action-hover" hover-stay-time="150" bindtap="goRanking">
      <view class="action-icon-wrap">🏆</view>
      <text class="action-text">查看群周榜</text>
      <text class="action-chevron">›</text>
    </view>
    <view class="action-item" hover-class="action-hover" hover-stay-time="150" loading="{{shareLoading}}" bindtap="openShareModal">
      <view class="action-icon-wrap">📤</view>
      <text class="action-text">分享运动数据</text>
      <text class="action-chevron">›</text>
    </view>
    <view wx:if="{{user.isAdmin}}" class="action-item" hover-class="action-hover" hover-stay-time="150" bindtap="goAdmin">
      <view class="action-icon-wrap">⚙️</view>
      <text class="action-text">后台管理</text>
      <text class="action-chevron">›</text>
    </view>
    <view class="action-item" hover-class="action-hover" hover-stay-time="150" bindtap="handleLogout">
      <view class="action-icon-wrap">🚪</view>
      <text class="action-text logout-text">退出登录</text>
      <text class="action-chevron">›</text>
    </view>
  </view>

</view>


<!-- 赞助二维码蒙层 -->
<view wx:if="{{showSponsor}}" class="sponsor-overlay" bindtap="closeSponsor">
  <view class="sponsor-modal" catchtap="">
    <view class="sponsor-title">请作者喝杯咖啡 ☕</view>
    <image class="sponsor-qr" src="{{sponsorQrUrl}}" mode="aspectFit" show-menu-by-longpress="true"/>
    <view class="sponsor-hint">
      <view>受微信小程序限制，无法长按识别</view>
      <view>请先保存图片，再到微信「扫一扫」选择相册识别</view>
    </view>
    <view class="sponsor-close" bindtap="closeSponsor">关闭</view>
  </view>
</view>

<!-- 分享运动数据蒙层 -->
<view wx:if="{{showShareModal}}" class="share-overlay" bindtap="closeShareModal">
  <view class="share-modal" catchtap="">
    <view class="share-title">分享运动数据 📤</view>
    <view class="share-text-box">
      <text class="share-text">{{shareText}}</text>
    </view>
    <view class="share-actions">
      <view class="share-copy-btn" bindtap="copyShareText">复制文案</view>
      <button class="share-forward-btn" open-type="share">分享给好友</button>
    </view>
    <view class="share-close" bindtap="closeShareModal">关闭</view>
  </view>
</view>
