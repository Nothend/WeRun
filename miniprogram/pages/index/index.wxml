<view class="container">

  <!-- 待审核申请提示卡 -->
  <view wx:if="{{isPending}}" class="card pending-banner">
    <view class="pending-banner-top">
      <text class="pending-banner-icon">⏳</text>
      <text class="pending-banner-title">申请审核中</text>
    </view>
    <view wx:if="{{nicknameIsDefault}}" class="pending-banner-body">
      <view class="pending-banner-msg">请设置你的昵称（使用微信昵称），方便管理员识别你的申请</view>
      <view class="pending-banner-btn" bindtap="goApply">设置昵称，提交申请 →</view>
    </view>
    <view wx:else class="pending-banner-body">
      <view class="pending-banner-msg">你的加入申请等待管理员审核，通过后即可参与打卡和查看排行榜</view>
      <view class="pending-banner-edit" bindtap="goApply">修改昵称</view>
    </view>
  </view>

  <!-- 个人资料 -->
  <view class="card profile-card">
    <view class="profile-row" bindtap="onProfileTap">
      <image class="avatar" src="{{avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
      <view class="profile-info">
        <text class="profile-name">{{user ? (nickname || '未设置昵称') : '未登录'}}</text>
        <text class="profile-sub">{{isPending ? '申请审核中 · 点击编辑资料' : (user ? '跑团成员 · 点击编辑资料' : '点击微信登录，解锁打卡与个人数据')}}</text>
      </view>
      <text wx:if="{{!user}}" class="profile-login-badge" hover-class="action-hover">{{loggingIn ? '登录中…' : '去登录'}}</text>
    </view>
    <view class="profile-stats">
      <view class="pstat-item" hover-class="{{stats ? 'pstat-hover' : ''}}" hover-stay-time="150" data-scope="week" bindtap="openRecords">
        <text class="pstat-num">{{stats ? stats.weekCount : '-'}}</text>
        <text class="pstat-label">本周打卡{{stats ? ' ›' : ''}}</text>
      </view>
      <view class="pstat-divider"></view>
      <view class="pstat-item" hover-class="{{stats ? 'pstat-hover' : ''}}" hover-stay-time="150" data-scope="all" bindtap="openRecords">
        <text class="pstat-num">{{stats ? stats.totalCount : '-'}}</text>
        <text class="pstat-label">总打卡次数{{stats ? ' ›' : ''}}</text>
      </view>
    </view>
    <view wx:if="{{stats && stats.todayCheckin}}" class="today-row">
      <text class="today-label">今日已打卡 · 约 {{stats.todayCheckin.duration}} 分钟</text>
      <text class="today-del" bindtap="deleteCheckinToday">撤销</text>
    </view>
  </view>

  <!-- 上传截图打卡 -->
  <view class="card checkin-card" hover-class="card-hover" hover-stay-time="150" bindtap="goCheckin">
    <view class="checkin-icon-wrap">📷</view>
    <view class="checkin-content">
      <text class="checkin-title">上传截图打卡</text>
      <text class="checkin-sub">上传运动截图，AI 识别时长</text>
    </view>
    <text class="action-chevron">›</text>
  </view>

  <!-- 快速入口 -->
  <view class="card actions-card">
    <view class="action-item" hover-class="action-hover" hover-stay-time="150" bindtap="goRanking">
      <view class="action-icon-wrap">🏆</view>
      <text class="action-text">查看排行榜</text>
      <text class="action-chevron">›</text>
    </view>
    <view class="action-item" hover-class="action-hover" hover-stay-time="150" bindtap="goAbout">
      <view class="action-icon-wrap">💗</view>
      <text class="action-text">关于作者</text>
      <text class="action-chevron">›</text>
    </view>
    <view wx:if="{{user.isAdmin}}" class="action-item" hover-class="action-hover" hover-stay-time="150" bindtap="goAdmin">
      <view class="action-icon-wrap">⚙️</view>
      <text class="action-text">后台管理</text>
      <text class="action-chevron">›</text>
    </view>
    <view wx:if="{{user}}" class="action-item" hover-class="action-hover" hover-stay-time="150" bindtap="handleLogout">
      <view class="action-icon-wrap">🚪</view>
      <text class="action-text logout-text">退出登录</text>
      <text class="action-chevron">›</text>
    </view>
    <view wx:if="{{!user}}" class="action-item" hover-class="action-hover" hover-stay-time="150" loading="{{loggingIn}}" bindtap="handleLogin">
      <view class="action-icon-wrap">👤</view>
      <text class="action-text">微信登录</text>
      <text class="action-chevron">›</text>
    </view>
  </view>

</view>
