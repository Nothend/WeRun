/* ── 项目介绍 ── */
.about-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 48rpx 40rpx;
}
.about-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}
.about-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #e2e8f0;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}
.about-desc {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.7;
}

/* ── 成本说明 ── */
.cost-card {
  padding: 36rpx 40rpx;
}
.cost-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e2e8f0;
  margin-bottom: 28rpx;
  letter-spacing: 0.5rpx;
}
.cost-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}
.cost-item + .cost-item {
  margin-top: 24rpx;
}
.cost-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}
.cost-text {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.6;
}

/* ── 赞赏支持 ── */
.support-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 44rpx 40rpx;
  border-color: rgba(34, 211, 238, 0.18);
}
.support-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e2e8f0;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}
.support-sub {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1.7;
  margin-bottom: 32rpx;
}
.pay-qr {
  width: 440rpx;
  border-radius: 16rpx;
  background: #fff;
  padding: 16rpx;
  box-sizing: content-box;
  margin-bottom: 24rpx;
}
.support-hint {
  font-size: 22rpx;
  color: #475569;
  letter-spacing: 1rpx;
}
