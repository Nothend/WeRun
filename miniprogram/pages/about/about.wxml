<view class="container">

  <notice-bar/>

  <view class="card about-card">
    <view class="about-icon">🏃</view>
    <view class="about-title">WeRun 跑团打卡</view>
    <view class="about-desc">用爱发电开发的小程序，希望能帮大家把跑步坚持下去。</view>
  </view>

  <!-- 更新日志：服务端从 git 标签自动生成，每次发版自动追加 -->
  <view wx:if="{{changelog.length > 0}}" class="card changelog-card">
    <view class="changelog-head">
      <text class="changelog-title">更新日志</text>
      <text class="changelog-summary">持续迭代 · 已发布 {{versionCount}} 个版本</text>
    </view>
    <view class="changelog-list">
      <view wx:for="{{changelog}}" wx:key="version" class="changelog-item">
        <view class="changelog-item-top">
          <text class="changelog-ver">{{item.version}}</text>
          <text wx:if="{{item.area}}" class="changelog-badge badge-{{item.areaClass}}">{{item.area}}</text>
          <text class="changelog-date">{{item.date}}</text>
        </view>
        <view class="changelog-text">{{item.text}}</view>
      </view>
    </view>
    <view wx:if="{{firstDate}}" class="changelog-foot">首个版本发布于 {{firstDate}}</view>
  </view>

  <!-- 支持区块：由服务器开关控制（remoteConfig.showSupport），默认隐藏 -->
  <block wx:if="{{showSupport}}">
    <view class="card cost-card">
      <view class="cost-title">为什么需要支持？</view>
      <view class="cost-item">
        <text class="cost-icon">💳</text>
        <text class="cost-text">微信小程序认证需要每年缴纳年费</text>
      </view>
      <view class="cost-item">
        <text class="cost-icon">📷</text>
        <text class="cost-text">截图自动核验服务按调用量计费</text>
      </view>
      <view class="cost-item">
        <text class="cost-icon">☁️</text>
        <text class="cost-text">服务器和域名也在持续产生费用</text>
      </view>
    </view>

    <view class="card support-card">
      <view class="support-title">💗 欢迎大家支持</view>
      <view class="support-sub">请作者喝杯水～金额随意，心意最重要！</view>
      <image
        class="pay-qr"
        src="{{payQrUrl}}"
        mode="widthFix"
        show-menu-by-longpress
        bindtap="previewQr"
      />
      <view class="support-hint">个人小程序不能长按识别付款码</view>
    </view>
  </block>

</view>
