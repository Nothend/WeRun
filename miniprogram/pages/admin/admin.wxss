/* ── 注销账号 ── */
.danger-card {
  padding: 32rpx 36rpx;
  border-color: rgba(239, 68, 68, 0.2);
  background: rgba(239, 68, 68, 0.04);
}
.danger-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ef4444;
  margin-bottom: 8rpx;
}
.danger-sub {
  font-size: 22rpx;
  color: #7f1d1d;
}

/* ── 标签页 ── */
.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  padding: 8rpx;
  margin: 0 0 24rpx;
  gap: 8rpx;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #475569;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 14rpx;
  transition: all 0.2s;
}
.tab-active {
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.1);
  border: 1rpx solid rgba(34, 211, 238, 0.2);
  font-weight: 600;
}

/* ── 通知设置卡 ── */
.notify-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 40rpx;
}
.notify-info {
  flex: 1;
  margin-right: 20rpx;
}
.notify-title {
  font-size: 28rpx;
  color: #e2e8f0;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.notify-desc {
  font-size: 22rpx;
  line-height: 1.5;
}

/* ── 打卡日志行 ── */
.log-row {
  display: flex;
  align-items: center;
  padding: 24rpx 40rpx;
}
.log-row + .log-row {
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.log-info {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}
.log-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.log-week {
  font-size: 22rpx;
}
.log-detail {
  font-size: 24rpx;
}

/* ── 加载更多 ── */
.load-more {
  padding: 28rpx 0;
  text-align: center;
}
.load-more-btn {
  display: inline-block;
  font-size: 24rpx;
  color: #22d3ee;
  padding: 12rpx 40rpx;
  border: 1rpx solid rgba(34, 211, 238, 0.25);
  border-radius: 40rpx;
}
.load-more-end {
  font-size: 22rpx;
}

/* ── 标题栏 ── */
.header-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
}
.header-left {}
.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #e2e8f0;
  letter-spacing: 2rpx;
}
.header-count {
  font-size: 24rpx;
  color: #334155;
  margin-top: 4rpx;
}
.import-btn {
  font-size: 24rpx;
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.08);
  border: 1rpx solid rgba(34, 211, 238, 0.25) !important;
  border-radius: 12rpx;
  padding: 0 28rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  flex-shrink: 0;
}
.import-btn::after {
  border: none;
}

/* ── 成员列表 ── */
.list-card {
  padding: 0;
  overflow: hidden;
}
.row {
  display: flex;
  align-items: center;
  padding: 28rpx 40rpx;
}
.row + .row {
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #1a2942;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.info {
  flex: 1;
  min-width: 0;
}
.name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.name {
  font-size: 28rpx;
  color: #e2e8f0;
}
.tag {
  font-size: 20rpx;
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
  line-height: 1.8;
}
.admin-tag {
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.08);
  border: 1rpx solid rgba(34, 211, 238, 0.25);
}
.me-tag {
  color: #475569;
  background: rgba(71, 85, 105, 0.12);
  border: 1rpx solid rgba(71, 85, 105, 0.2);
}
.openid-row {
  margin: 4rpx 0 2rpx;
}
.openid-text {
  font-size: 20rpx;
  color: #334155;
  font-family: monospace;
  letter-spacing: 0.5rpx;
}
.checkins {
  font-size: 24rpx;
}
.ops {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.op-btn {
  margin: 0;
  font-size: 22rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 16rpx;
  color: #64748b;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.07) !important;
  border-radius: 8rpx;
}
.op-btn::after {
  border: none;
}
.rename-btn {
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.06);
  border: 1rpx solid rgba(34, 211, 238, 0.18) !important;
}
.op-btn.danger {
  color: #f87171;
  background: rgba(248, 113, 113, 0.06);
  border: 1rpx solid rgba(248, 113, 113, 0.18) !important;
}
.empty {
  text-align: center;
  padding: 72rpx 0;
}

/* ── 导入说明卡 ── */
.hint-card {
  padding: 28rpx 40rpx;
}
.hint-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #475569;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}
.hint-row {
  font-size: 22rpx;
  color: #334155;
  margin-bottom: 8rpx;
  line-height: 1.6;
}
.hint-code {
  font-family: monospace;
  color: #22d3ee;
  background: rgba(34, 211, 238, 0.06);
  border-radius: 4rpx;
  padding: 2rpx 8rpx;
}

/* ── 弹窗 ── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  background: #0f1e33;
  border: 1rpx solid rgba(34, 211, 238, 0.18);
  border-radius: 28rpx;
  padding: 48rpx 44rpx 40rpx;
  width: 580rpx;
  display: flex;
  flex-direction: column;
}
.modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #e2e8f0;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
  text-align: center;
}
.modal-cur {
  font-size: 24rpx;
  text-align: center;
  margin-bottom: 28rpx;
}
.modal-input {
  width: 100%;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(34, 211, 238, 0.15);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #e2e8f0;
  margin-bottom: 32rpx;
}
.modal-btns {
  display: flex;
  gap: 20rpx;
}
.modal-btn-cancel {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #475569;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
}
.modal-btn-confirm {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #0ea5e9, #22d3ee);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(34, 211, 238, 0.2);
}
.btn-disabled {
  opacity: 0.5;
}

/* ── 导入结果 ── */
.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}
.result-lbl {
  font-size: 26rpx;
  color: #475569;
}
.result-val {
  font-size: 26rpx;
  font-weight: 600;
  color: #e2e8f0;
}
.result-val.green {
  color: #4ade80;
}
.result-errors {
  margin-top: 20rpx;
  background: rgba(248, 113, 113, 0.04);
  border: 1rpx solid rgba(248, 113, 113, 0.1);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  max-height: 200rpx;
  overflow-y: auto;
}
.result-err-title {
  font-size: 22rpx;
  margin-bottom: 10rpx;
}
.result-err-item {
  font-size: 22rpx;
  color: #f87171;
  line-height: 1.6;
}
