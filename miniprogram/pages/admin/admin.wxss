/* ── 待审核申请卡 ── */
.applications-card {
  border-color: rgba(234, 179, 8, 0.35);
  background: rgba(234, 179, 8, 0.06);
}
.applications-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.applications-count {
  font-size: 22rpx;
  font-weight: 600;
  color: #d48806;
  background: rgba(234, 179, 8, 0.18);
  border-radius: 100rpx;
  padding: 4rpx 18rpx;
}
.pending-tag {
  font-size: 18rpx;
  color: #d48806;
  background: rgba(234, 179, 8, 0.15);
  border: 1rpx solid rgba(234, 179, 8, 0.3);
  border-radius: 8rpx;
  padding: 2rpx 12rpx;
}
.approve-btn {
  color: #07c160 !important;
  border-color: rgba(7, 193, 96, 0.4) !important;
}

/* ── 注销账号 ── */
.danger-card {
  padding: 32rpx 36rpx;
  border-color: rgba(250, 81, 81, 0.3);
  background: rgba(250, 81, 81, 0.06);
}
.danger-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fa5151;
  margin-bottom: 8rpx;
}
.danger-sub {
  font-size: 22rpx;
  color: #c62828;
}

/* ── 标签页 ── */
.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin: 0 0 24rpx;
  gap: 8rpx;
}
.tab {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #8a9099;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 14rpx;
  transition: all 0.2s;
}
.tab-active {
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  border: 1rpx solid rgba(7, 193, 96, 0.25);
  font-weight: 600;
}

/* ── 通知设置卡 ── */
.notify-card {
  padding: 0;
  flex-direction: column;
}
.notify-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 40rpx;
}
.notify-row-border {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.notify-info {
  flex: 1;
  margin-right: 20rpx;
}
.notify-title {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.notify-desc {
  font-size: 22rpx;
  line-height: 1.5;
}
.subscribe-apply-btn {
  font-size: 24rpx !important;
  color: #07c160 !important;
  background: rgba(7, 193, 96, 0.08) !important;
  border: 1rpx solid rgba(7, 193, 96, 0.35) !important;
  border-radius: 16rpx !important;
  padding: 0 28rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  flex-shrink: 0;
}
.subscribe-apply-btn::after { border: none; }

/* ── 滚动公告设置 ── */
.notice-setting-card {
  flex-direction: column;
  align-items: stretch;
  padding: 28rpx 40rpx;
}
.notice-title {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 6rpx;
}
.notice-desc {
  font-size: 22rpx;
  line-height: 1.5;
  margin-bottom: 16rpx;
}
.notice-input {
  width: 100%;
  box-sizing: border-box;
  min-height: 88rpx;
  padding: 18rpx 22rpx;
  font-size: 26rpx;
  color: #1a1a1a;
  background: #f6f7f9;
  border-radius: 14rpx;
}
.notice-save-btn {
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #fff;
  background: #07c160;
  border-radius: 16rpx;
  height: 72rpx;
  line-height: 72rpx;
}
.notice-save-btn::after { border: none; }

/* ── 打卡日志行 ── */
.log-row {
  display: flex;
  align-items: center;
  padding: 24rpx 40rpx;
}
.log-row + .log-row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.log-info {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}
.log-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.log-week {
  font-size: 22rpx;
}
.log-detail {
  font-size: 24rpx;
}

/* ── 加载更多 ── */
.load-more {
  padding: 28rpx 0;
  text-align: center;
}
.load-more-btn {
  display: inline-block;
  font-size: 24rpx;
  color: #07c160;
  padding: 12rpx 40rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.3);
  border-radius: 40rpx;
}
.load-more-end {
  font-size: 22rpx;
}

/* ── 标题栏 ── */
.header-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
}
.header-left {}
.header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 2rpx;
}
.header-count {
  font-size: 24rpx;
  color: #aab0b8;
  margin-top: 4rpx;
}
.import-btn {
  font-size: 24rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.08);
  border: 1rpx solid rgba(7, 193, 96, 0.3) !important;
  border-radius: 12rpx;
  padding: 0 28rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  flex-shrink: 0;
}
.import-btn::after {
  border: none;
}

/* ── 成员列表 ── */
.list-card {
  padding: 0;
  overflow: hidden;
}
.row {
  display: flex;
  align-items: center;
  padding: 28rpx 40rpx;
}
.row + .row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #eef1f5;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.info {
  flex: 1;
  min-width: 0;
}
.name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.name {
  font-size: 28rpx;
  color: #1a1a1a;
}
.tag {
  font-size: 20rpx;
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
  line-height: 1.8;
}
.admin-tag {
  color: #07c160;
  background: rgba(7, 193, 96, 0.08);
  border: 1rpx solid rgba(7, 193, 96, 0.3);
}
.me-tag {
  color: #8a9099;
  background: rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.1);
}
.openid-row {
  margin: 4rpx 0 2rpx;
}
.openid-text {
  font-size: 20rpx;
  color: #aab0b8;
  font-family: monospace;
  letter-spacing: 0.5rpx;
}
.checkins {
  font-size: 24rpx;
}
.ops {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.op-btn {
  margin: 0;
  font-size: 22rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 16rpx;
  color: #5a6270;
  background: #f5f7fa;
  border: 1rpx solid rgba(0, 0, 0, 0.1) !important;
  border-radius: 8rpx;
}
.op-btn::after {
  border: none;
}
.rename-btn {
  color: #07c160;
  background: rgba(7, 193, 96, 0.08);
  border: 1rpx solid rgba(7, 193, 96, 0.3) !important;
}
.op-btn.danger {
  color: #fa5151;
  background: rgba(250, 81, 81, 0.08);
  border: 1rpx solid rgba(250, 81, 81, 0.3) !important;
}
.empty {
  text-align: center;
  padding: 72rpx 0;
}

/* ── 导入说明卡 ── */
.hint-card {
  padding: 28rpx 40rpx;
}
.hint-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #8a9099;
  letter-spacing: 1rpx;
  margin-bottom: 16rpx;
}
.hint-row {
  font-size: 22rpx;
  color: #8a9099;
  margin-bottom: 8rpx;
  line-height: 1.6;
}
.hint-code {
  font-family: monospace;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  border-radius: 4rpx;
  padding: 2rpx 8rpx;
}

/* ── 待匹配导入记录 ── */
.pending-card {
  padding: 28rpx 40rpx;
}
.pending-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
}
.pending-row + .pending-row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.pending-info {
  flex: 1;
  min-width: 0;
}
.pending-meta {
  font-size: 22rpx;
  margin-top: 6rpx;
}
.match-list {
  max-height: 480rpx;
  margin-bottom: 24rpx;
}
.match-row {
  display: flex;
  align-items: center;
  padding: 18rpx 12rpx;
  border-radius: 12rpx;
}
.match-row:active {
  background: rgba(7, 193, 96, 0.08);
}
.match-row .avatar {
  width: 64rpx;
  height: 64rpx;
  margin-right: 16rpx;
}
.match-row .name {
  font-size: 26rpx;
}

/* ── 弹窗 ── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.modal-box {
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 28rpx;
  padding: 48rpx 44rpx 40rpx;
  width: 580rpx;
  display: flex;
  flex-direction: column;
}
.modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
  text-align: center;
}
.modal-cur {
  font-size: 24rpx;
  text-align: center;
  margin-bottom: 28rpx;
}
.modal-input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  margin-bottom: 32rpx;
}
.modal-btns {
  display: flex;
  gap: 20rpx;
}
.modal-btn-cancel {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #5a6270;
  background: #f5f7fa;
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 16rpx;
}
.modal-btn-confirm {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #07c160, #06ad56);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}
.btn-disabled {
  opacity: 0.5;
}

/* ── 导入结果 ── */
.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}
.result-lbl {
  font-size: 26rpx;
  color: #8a9099;
}
.result-val {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.result-val.green {
  color: #07c160;
}
.result-val.warn {
  color: #d48806;
}
.result-errors {
  margin-top: 20rpx;
  background: rgba(250, 81, 81, 0.06);
  border: 1rpx solid rgba(250, 81, 81, 0.15);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  max-height: 200rpx;
  overflow-y: auto;
}
.result-err-title {
  font-size: 22rpx;
  margin-bottom: 10rpx;
}
.result-err-item {
  font-size: 22rpx;
  color: #fa5151;
  line-height: 1.6;
}
