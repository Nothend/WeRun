<view class="container">

  <!-- 标签页切换 -->
  <view class="tabs">
    <view class="tab {{activeTab === 'members' ? 'tab-active' : ''}}"
          data-tab="members" bindtap="switchTab">成员管理</view>
    <view class="tab {{activeTab === 'logs' ? 'tab-active' : ''}}"
          data-tab="logs" bindtap="switchTab">打卡日志</view>
  </view>

  <!-- ══════════════════ 成员管理 tab ══════════════════ -->
  <block wx:if="{{activeTab === 'members'}}">

    <!-- 标题栏 -->
    <view class="card header-card">
      <view class="header-left">
        <view class="header-title">成员管理</view>
        <view class="header-count">{{list.length}} 位成员</view>
      </view>
      <button wx:if="{{showImport}}" class="import-btn" loading="{{importLoading}}" bindtap="importExcel">导入数据</button>
    </view>

    <!-- 待审核申请 -->
    <view wx:if="{{applications.length > 0}}" class="card applications-card">
      <view class="applications-header">
        <view class="header-title">待审核申请</view>
        <view class="applications-count">{{applications.length}}</view>
      </view>
      <view wx:for="{{applications}}" wx:key="openid" class="row">
        <image class="avatar" src="{{item.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
        <view class="info">
          <view class="name-row">
            <text class="name">{{item.nickname || '未设昵称'}}</text>
            <view class="tag pending-tag">待审核</view>
          </view>
          <view class="openid-row" data-openid="{{item.openid}}" bindtap="copyOpenid">
            <text class="openid-text">{{item.openid}}</text>
          </view>
        </view>
        <view class="ops">
          <button size="mini" class="op-btn approve-btn"
                  data-openid="{{item.openid}}" data-nickname="{{item.nickname}}"
                  loading="{{approvingOpenid === item.openid}}"
                  bindtap="approveUser">通过</button>
          <button size="mini" class="op-btn danger"
                  data-openid="{{item.openid}}" data-nickname="{{item.nickname}}"
                  bindtap="rejectUser">拒绝</button>
        </view>
      </view>
    </view>

    <!-- 通知设置卡（仅管理员可见） -->
    <view class="card notify-card">
      <view class="notify-row">
        <view class="notify-info">
          <view class="notify-title">新成员申请通知</view>
          <view class="notify-desc muted">订阅后，有新成员申请时你将收到微信通知（每次点击订阅一次）</view>
        </view>
        <button class="subscribe-apply-btn" bindtap="subscribeApplyNotify">订阅</button>
      </view>
    </view>

    <!-- 滚动公告设置 -->
    <view class="card notice-setting-card">
      <view class="notice-title">首页滚动公告</view>
      <view class="notice-desc muted">显示在首页顶部，所有成员可见；留空并保存即撤下公告</view>
      <textarea class="notice-input" value="{{noticeText}}" bindinput="onNoticeInput"
                placeholder="输入公告内容（100 字以内）" maxlength="100" auto-height/>
      <button class="notice-save-btn {{savingNotice ? 'btn-disabled' : ''}}"
              loading="{{savingNotice}}" bindtap="saveNotice">保存公告</button>
    </view>

    <!-- 成员列表 -->
    <view class="card list-card">
      <view wx:for="{{list}}" wx:key="openid" class="row">
        <image class="avatar" src="{{item.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
        <view class="info">
          <view class="name-row">
            <text class="name">{{item.nickname || '未设昵称'}}</text>
            <view wx:if="{{item.isAdmin}}" class="tag admin-tag">管理员</view>
            <view wx:if="{{item.openid === myOpenid}}" class="tag me-tag">我</view>
          </view>
          <view class="openid-row" data-openid="{{item.openid}}" bindtap="copyOpenid">
            <text class="openid-text">{{item.openid}}</text>
          </view>
          <view class="checkins muted">累计 {{item.totalCheckins}} 次打卡</view>
        </view>
        <view class="ops">
          <button size="mini" class="op-btn rename-btn"
                  data-openid="{{item.openid}}" data-nickname="{{item.nickname}}"
                  bindtap="openRenameModal">改名</button>
          <button size="mini" class="op-btn"
                  data-openid="{{item.openid}}" data-nickname="{{item.nickname}}"
                  data-isadmin="{{item.isAdmin}}" bindtap="toggleAdmin">
            {{item.isAdmin ? '取消管理' : '设管理'}}
          </button>
          <button wx:if="{{item.openid !== myOpenid}}" size="mini" class="op-btn danger"
                  data-openid="{{item.openid}}" data-nickname="{{item.nickname}}" bindtap="kick">
            踢出
          </button>
        </view>
      </view>
      <view wx:if="{{!loading && list.length === 0}}" class="empty muted">暂无成员</view>
    </view>

    <!-- 注销账号 -->
    <view class="card danger-card" bindtap="deleteAccount">
      <view class="danger-text">注销账号（永久删除）</view>
      <view class="danger-sub">删除当前微信账号及全部打卡记录，不可恢复</view>
    </view>

    <!-- 导入说明 -->
    <view wx:if="{{showImport}}" class="card hint-card">
      <view class="hint-title">Excel 导入格式说明</view>
      <view class="hint-row">列名：<text class="hint-code">用户昵称</text> 和 <text class="hint-code">打卡时间</text></view>
      <view class="hint-row">日期格式：<text class="hint-code">2026-06-05</text> 或 <text class="hint-code">2026/06/05</text></view>
      <view class="hint-row muted">需先将 Excel 文件发到微信聊天，再点「导入数据」从文件中选取</view>
    </view>

    <!-- 待匹配导入记录：导入时尚未加入小程序的成员 -->
    <view wx:if="{{showImport && pendingImports.length > 0}}" class="card pending-card">
      <view class="header-title">待匹配导入记录</view>
      <view class="hint-row muted" style="margin-top:8rpx">这些昵称导入时尚未加入小程序，待其登录后可关联到对应成员</view>
      <view wx:for="{{pendingImports}}" wx:key="nickname" class="pending-row">
        <view class="pending-info">
          <text class="name">{{item.nickname}}</text>
          <view class="muted pending-meta">{{item.count}} 条 · {{item.firstDate}} ~ {{item.lastDate}}</view>
        </view>
        <view class="ops">
          <button size="mini" class="op-btn rename-btn"
                  data-nickname="{{item.nickname}}" data-count="{{item.count}}" bindtap="openMatchModal">匹配</button>
          <button size="mini" class="op-btn danger"
                  data-nickname="{{item.nickname}}" data-count="{{item.count}}" bindtap="discardPending">丢弃</button>
        </view>
      </view>
    </view>

  </block>

  <!-- ══════════════════ 打卡日志 tab ══════════════════ -->
  <block wx:if="{{activeTab === 'logs'}}">

    <!-- 标题栏 -->
    <view class="card header-card">
      <view class="header-left">
        <view class="header-title">打卡日志</view>
        <view class="header-count">共 {{logsTotal}} 条</view>
      </view>
      <button class="import-btn" loading="{{logsLoading && logsPage === 1}}" bindtap="refreshLogs">刷新</button>
    </view>

    <!-- 日志列表 -->
    <view class="card list-card">
      <view wx:for="{{logs}}" wx:key="id" class="log-row">
        <image class="avatar" src="{{item.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
        <view class="log-info">
          <view class="log-name-row">
            <text class="name">{{item.nickname}}</text>
            <text class="log-week muted">{{item.weekKey}}</text>
          </view>
          <view class="log-detail muted">{{item.createdAtText}}  · {{item.durationMinutes}} 分钟</view>
        </view>
      </view>

      <view wx:if="{{logsLoading && logsPage === 1}}" class="empty muted">加载中…</view>
      <view wx:if="{{!logsLoading && logs.length === 0}}" class="empty muted">暂无打卡记录</view>

      <!-- 加载更多 -->
      <view wx:if="{{logs.length > 0}}" class="load-more">
        <view wx:if="{{logsHasMore}}" class="load-more-btn {{logsLoading ? 'btn-disabled' : ''}}"
              bindtap="loadMoreLogs">
          {{logsLoading ? '加载中…' : '加载更多'}}
        </view>
        <view wx:else class="load-more-end muted">已显示全部 {{logsTotal}} 条</view>
      </view>
    </view>

  </block>

</view>

<!-- 改名弹窗 -->
<view wx:if="{{renameModal}}" class="modal-overlay" catchtap="closeRenameModal">
  <view class="modal-box" catchtap="">
    <view class="modal-title">修改昵称</view>
    <view class="modal-cur muted">当前：{{renameTarget.nickname || '未设昵称'}}</view>
    <input class="modal-input" value="{{newNickname}}" bindinput="onNewNicknameInput"
           placeholder="输入新昵称" maxlength="20" focus="{{renameModal}}"/>
    <view class="modal-btns">
      <view class="modal-btn-cancel" bindtap="closeRenameModal">取消</view>
      <view class="modal-btn-confirm {{renaming ? 'btn-disabled' : ''}}" bindtap="confirmRename">
        {{renaming ? '保存中…' : '确定'}}
      </view>
    </view>
  </view>
</view>

<!-- 导入结果弹窗 -->
<view wx:if="{{showImportResult && importResult}}" class="modal-overlay" catchtap="closeImportResult">
  <view class="modal-box" catchtap="">
    <view class="modal-title">导入结果</view>
    <view class="result-row">
      <text class="result-lbl">共处理</text>
      <text class="result-val">{{importResult.total}} 行</text>
    </view>
    <view class="result-row">
      <text class="result-lbl">成功插入</text>
      <text class="result-val green">{{importResult.inserted}} 条</text>
    </view>
    <view wx:if="{{importResult.pending > 0}}" class="result-row">
      <text class="result-lbl">待匹配（成员未加入）</text>
      <text class="result-val">{{importResult.pending}} 条</text>
    </view>
    <view class="result-row">
      <text class="result-lbl">已跳过（当天已有打卡）</text>
      <text class="result-val">{{importResult.skipped}} 条</text>
    </view>
    <view wx:if="{{importResult.imprecise > 0}}" class="result-row">
      <text class="result-lbl">时间不精确跳过（缺时分秒）</text>
      <text class="result-val warn">{{importResult.imprecise}} 条</text>
    </view>
    <view wx:if="{{importResult.pending > 0}}" class="muted" style="font-size:22rpx;margin-top:16rpx;line-height:1.6">
      未匹配到现有成员的记录已暂存，可在「待匹配导入记录」中等成员加入后手动关联
    </view>
    <view wx:if="{{importResult.errors.length > 0}}" class="result-errors">
      <view class="result-err-title muted">格式错误：</view>
      <view wx:for="{{importResult.errors}}" wx:key="index" class="result-err-item">{{item}}</view>
    </view>
    <view class="modal-btn-confirm" style="margin-top:28rpx;text-align:center" bindtap="closeImportResult">关闭</view>
  </view>
</view>

<!-- 匹配用户弹窗 -->
<view wx:if="{{matchModal}}" class="modal-overlay" catchtap="closeMatchModal">
  <view class="modal-box" catchtap="">
    <view class="modal-title">匹配用户</view>
    <view class="modal-cur muted">将「{{matchTarget.nickname}}」的 {{matchTarget.count}} 条记录关联到：</view>
    <scroll-view scroll-y class="match-list">
      <view wx:for="{{list}}" wx:key="openid" class="match-row"
            data-openid="{{item.openid}}" data-nickname="{{item.nickname}}" bindtap="pickMatchUser">
        <image class="avatar" src="{{item.avatarUrl || '/assets/default-avatar.png'}}" mode="aspectFill"/>
        <text class="name">{{item.nickname || '未设昵称'}}</text>
      </view>
    </scroll-view>
    <view class="modal-btns">
      <view class="modal-btn-cancel" bindtap="closeMatchModal">取消</view>
    </view>
  </view>
</view>
