/* ── 上传区 ── */
.upload-zone {
  width: 100%;
  height: 460rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(7, 193, 96, 0.3);
  background: rgba(7, 193, 96, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 28rpx;
}
.preview-img {
  width: 100%;
  height: 100%;
}
.upload-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}
.upload-icon {
  font-size: 80rpx;
  opacity: 0.35;
}
.upload-label {
  font-size: 28rpx;
  color: #8a9099;
  letter-spacing: 1rpx;
}
.upload-sub {
  font-size: 22rpx;
}
.upload-meta {
  text-align: center;
  margin-bottom: 28rpx;
  line-height: 1.6;
}
.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
}

/* 已打卡完成态：绿色实底，区别于"不可用"的半透明置灰 */
.submit-btn-done[disabled] {
  opacity: 1;
  background: linear-gradient(135deg, #07c160, #06ad56);
  box-shadow: none;
}

/* ── 结果卡 ── */
.result-card {
  border-left: 4rpx solid transparent;
}
.result-card.ok {
  border-left-color: #07c160;
  background: rgba(7, 193, 96, 0.06);
}
.result-card.already {
  border-left-color: #07c160;
  background: rgba(7, 193, 96, 0.06);
}
.result-card.no {
  border-left-color: #fa5151;
  background: rgba(250, 81, 81, 0.06);
}
.result-icon {
  font-size: 64rpx;
  text-align: center;
  margin-bottom: 16rpx;
}
.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #07c160;
  text-align: center;
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
}
.result-title.fail {
  color: #fa5151;
}
.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}
.result-row:last-of-type {
  border-bottom: none;
}
.result-label {
  font-size: 26rpx;
  color: #8a9099;
}
.result-val {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
}
.result-val.accent {
  color: #07c160;
}
.result-achieved {
  text-align: center;
  color: #07c160;
  font-weight: 600;
  font-size: 30rpx;
  margin-top: 24rpx;
  letter-spacing: 1rpx;
}
.result-reason {
  font-size: 28rpx;
  color: #8a9099;
  text-align: center;
  margin-bottom: 16rpx;
  line-height: 1.6;
}
.mock-note {
  text-align: center;
  margin-top: 20rpx;
}
.ai-detail {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #f5f7fa;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 12rpx;
}
.ai-detail-title {
  font-size: 22rpx;
  color: #8a9099;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
}
.ai-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}
.ai-detail-row + .ai-detail-row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.ai-detail-label {
  font-size: 24rpx;
  color: #8a9099;
}
.ai-detail-val {
  font-size: 26rpx;
  color: #5a6270;
  font-weight: 500;
}
.delete-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background: rgba(250, 81, 81, 0.08);
  color: #fa5151;
  border: 1rpx solid rgba(250, 81, 81, 0.25);
  border-radius: 16rpx;
  text-align: center;
}
.delete-btn::after {
  border: none;
}
