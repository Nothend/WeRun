/* ── 上传区 ── */
.upload-zone {
  width: 100%;
  height: 300rpx;
  border-radius: var(--r-md);
  border: 2rpx dashed rgba(0, 0, 0, 0.12);
  background: #fafbfc;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 28rpx;
  transition: height 0.25s ease;
}
/* 出结果后上传区已无需细看，收成小缩略图，把整屏让给结果卡 */
.upload-zone.collapsed {
  height: 140rpx;
}
.preview-img {
  width: 100%;
  height: 100%;
}
.upload-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}
.upload-icon {
  font-size: 76rpx;
  color: var(--brand);
  opacity: 0.55;
}
.upload-label {
  font-size: 28rpx;
  color: var(--text-2);
  letter-spacing: 1rpx;
}
.upload-sub {
  font-size: 22rpx;
}
.upload-meta {
  text-align: center;
  margin-bottom: 28rpx;
  line-height: 1.6;
}
.submit-btn {
  width: 100%;
  height: 88rpx;
  font-size: 30rpx;
}

/* 已打卡完成态：绿色实底，区别于"不可用"的半透明置灰 */
.submit-btn-done[disabled] {
  opacity: 1;
  background: var(--brand);
  box-shadow: none;
}

/* ── 结果卡 ── */
.result-card {
  border-left: 4rpx solid transparent;
}
.result-card.ok {
  border-left-color: #07c160;
  background: rgba(7, 193, 96, 0.06);
}
.result-card.already {
  border-left-color: #07c160;
  background: rgba(7, 193, 96, 0.06);
}
.result-card.no {
  border-left-color: #fa5151;
  background: rgba(250, 81, 81, 0.06);
}
.result-icon {
  font-size: 64rpx;
  text-align: center;
  margin-bottom: 16rpx;
}
.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #07c160;
  text-align: center;
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
}
.result-title.fail {
  color: #fa5151;
}
.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}
.result-row:last-of-type {
  border-bottom: none;
}
.result-label {
  font-size: 26rpx;
  color: #8a9099;
}
.result-val {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
}
.result-val.accent {
  color: #07c160;
}
.result-achieved {
  text-align: center;
  color: #07c160;
  font-weight: 600;
  font-size: 30rpx;
  margin-top: 24rpx;
  letter-spacing: 1rpx;
}
.result-reason {
  font-size: 28rpx;
  color: #8a9099;
  text-align: center;
  margin-bottom: 16rpx;
  line-height: 1.6;
}
.mock-note {
  text-align: center;
  margin-top: 20rpx;
}
.ai-detail {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  background: #f5f7fa;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  border-radius: 12rpx;
}
.ai-detail-title {
  font-size: 22rpx;
  color: #8a9099;
  letter-spacing: 1rpx;
  margin-bottom: 14rpx;
}
.ai-detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}
.ai-detail-row + .ai-detail-row {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.ai-detail-label {
  font-size: 24rpx;
  color: #8a9099;
}
.ai-detail-val {
  font-size: 26rpx;
  color: #5a6270;
  font-weight: 500;
}
.delete-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background: rgba(250, 81, 81, 0.08);
  color: #fa5151;
  border: 1rpx solid rgba(250, 81, 81, 0.25);
  border-radius: 16rpx;
  text-align: center;
}
.delete-btn::after {
  border: none;
}
.result-hint {
  font-size: 24rpx;
  color: #8a9099;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 8rpx;
}
.retry-btn {
  margin-top: 28rpx;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  background: rgba(7, 193, 96, 0.08);
  color: #07c160;
  border: 1rpx solid rgba(7, 193, 96, 0.3);
  border-radius: 16rpx;
  text-align: center;
}
.retry-btn::after {
  border: none;
}

/* ── 核验等待遮罩 ── */
.checkin-loading {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.45);
}
.checkin-loading-box {
  width: 520rpx;
  padding: 48rpx 40rpx 28rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.checkin-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(7, 193, 96, 0.15);
  border-top-color: #07c160;
  border-radius: 50%;
  animation: checkin-spin 0.8s linear infinite;
}
@keyframes checkin-spin {
  100% { transform: rotate(360deg); }
}
.checkin-loading-text {
  margin: 24rpx 0;
  font-size: 28rpx;
  color: #333;
}
/* 遮罩内的公告占满弹窗宽度（组件根节点 class）；公告为空时组件不渲染，仅留转圈与文案 */
.loading-notice {
  width: 100%;
}
