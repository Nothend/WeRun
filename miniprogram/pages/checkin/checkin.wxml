<view class="container">

  <notice-bar/>

  <view class="card">
    <!-- 上传区 -->
    <view class="upload-zone" bindtap="chooseImage">
      <image wx:if="{{imagePath}}" src="{{imagePath}}" mode="aspectFit" class="preview-img"/>
      <view wx:else class="upload-empty">
        <view class="upload-icon">📷</view>
        <view class="upload-label">点击选择 / 拍摄</view>
        <view class="muted upload-sub">支持相册或实时拍摄</view>
      </view>
    </view>

    <view class="upload-meta muted">系统自动核验运动时长，≥ {{minDurationMinutes}} 分钟计为一次打卡</view>

    <!-- 打卡成功/今日已打卡后按钮变为不可点的完成态，避免误以为还没提交 -->
    <button wx:if="{{result && (result.success || result.already)}}"
            class="btn-primary submit-btn submit-btn-done" disabled>
      ✅ 今日已打卡
    </button>
    <button wx:else
            class="btn-primary submit-btn"
            loading="{{submitting}}"
            disabled="{{!imagePath || submitting}}"
            bindtap="submit">
      提交打卡
    </button>
  </view>

  <!-- 打卡结果 -->
  <view wx:if="{{result}}" class="card result-card {{result.success ? 'ok' : result.already ? 'already' : 'no'}}">
    <!-- 打卡成功 -->
    <view wx:if="{{result.success}}">
      <view class="result-icon">✅</view>
      <view class="result-title">打卡成功</view>
      <view class="result-row">
        <text class="result-label">运动日期</text>
        <text class="result-val">{{result.exercise_date || '今日'}}</text>
      </view>
      <view class="result-row">
        <text class="result-label">运动时长</text>
        <text class="result-val">{{result.durationText}}</text>
      </view>
      <block wx:if="{{result.secCheckMs}}">
        <view class="result-row">
          <text class="result-label">内容安全检测</text>
          <text class="result-val">✓ 已通过（{{result.secCheckText}}）</text>
        </view>
        <view class="result-row">
          <text class="result-label">图片识别用时</text>
          <text class="result-val">{{result.recognizeText}}</text>
        </view>
      </block>
      <view class="result-row">
        <text class="result-label">本周已打卡</text>
        <text class="result-val accent">{{result.weekCount}} / {{result.target}} 次</text>
      </view>
      <view wx:if="{{result.achieved}}" class="result-achieved">🎉 本周已达标！</view>
      <view wx:if="{{result.mock}}" class="muted mock-note">（演示模式数据）</view>
    </view>
    <!-- 今天已打过卡（不是错误，是提示） -->
    <view wx:elif="{{result.already}}">
      <view class="result-icon">✅</view>
      <view class="result-title">今天已打过卡</view>
      <view wx:if="{{result.duration}}" class="result-row">
        <text class="result-label">已记录时长</text>
        <text class="result-val">{{result.durationText}}</text>
      </view>
      <view class="result-row">
        <text class="result-label">本周已打卡</text>
        <text class="result-val accent">{{result.weekCount}} / {{result.target}} 次</text>
      </view>
      <button class="delete-btn" bindtap="deleteCheckin">撤销今日打卡</button>
    </view>
    <!-- 打卡未成功 -->
    <view wx:else>
      <view class="result-icon">❌</view>
      <view class="result-title fail">打卡未成功</view>
      <view class="result-reason">{{result.reason}}</view>
      <view class="result-hint">按上方提示调整后，重新选择一张清晰完整的运动记录截图再试～</view>
      <!-- 核验详情：让用户直观看到系统从截图中读取了什么 -->
      <view wx:if="{{result.exercise_date || result.duration > 0}}" class="ai-detail">
        <view class="ai-detail-title">截图核验结果</view>
        <view wx:if="{{result.exercise_date}}" class="ai-detail-row">
          <text class="ai-detail-label">运动日期</text>
          <text class="ai-detail-val">{{result.exercise_date}}</text>
        </view>
        <view wx:if="{{result.duration > 0}}" class="ai-detail-row">
          <text class="ai-detail-label">运动时长</text>
          <text class="ai-detail-val">{{result.durationText}}</text>
        </view>
      </view>
      <button class="retry-btn" bindtap="chooseImage">重新选择截图</button>
    </view>
  </view>

  <!-- 核验等待遮罩：转圈 + 复用滚动公告，让等待几秒时有内容可看 -->
  <view wx:if="{{submitting}}" class="checkin-loading">
    <view class="checkin-loading-box">
      <view class="checkin-spinner"></view>
      <text class="checkin-loading-text">核验中，约需几秒…</text>
      <notice-bar class="loading-notice"/>
    </view>
  </view>
</view>
