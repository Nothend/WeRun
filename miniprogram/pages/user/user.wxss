.page {
  display: flex;
  flex-direction: column;
}

/* ── 用户资料头 ── */
.profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 44rpx 0 32rpx;
}
.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #eef1f5;
  border: 2rpx solid rgba(7, 193, 96, 0.3);
  box-shadow: 0 0 16rpx rgba(7, 193, 96, 0.12);
}
.profile-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}

/* ── 周期标签 ── */
.tabs {
  display: flex;
  background: #ffffff;
  border-radius: 20rpx;
  margin: 0 24rpx;
  padding: 8rpx;
  gap: 6rpx;
}
.tab {
  flex: 1;
  min-width: 0;
  text-align: center;
  font-size: 24rpx;
  color: #8a9099;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 12rpx;
}
.tab-active {
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  font-weight: 600;
}

/* ── 内容区 ── */
.container {
  padding: 24rpx 24rpx 64rpx;
}

.summary-card {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
}
.summary-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.summary-num {
  font-size: 52rpx;
  font-weight: 800;
  color: #07c160;
  line-height: 1;
  letter-spacing: -1rpx;
}
.summary-label {
  font-size: 20rpx;
  color: #8a9099;
  letter-spacing: 2rpx;
}
.summary-divider {
  width: 1rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.08);
}

.goal-line {
  text-align: center;
  font-size: 24rpx;
  color: #8a9099;
  margin: -8rpx 0 24rpx;
  letter-spacing: 0.5rpx;
}
.goal-line.ok {
  color: #07c160;
}

/* ── 明细列表 ── */
.list-card {
  padding: 0;
  overflow: hidden;
}
.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx;
}
.record-item + .record-item {
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.record-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.record-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.record-meta {
  font-size: 22rpx;
  color: #8a9099;
  letter-spacing: 0.5rpx;
}
.record-duration {
  font-size: 28rpx;
  font-weight: 700;
  color: #07c160;
}

.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: #8a9099;
  padding: 80rpx 0;
}
.loading {
  text-align: center;
  padding: 48rpx 0;
}
