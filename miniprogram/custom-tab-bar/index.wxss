.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}
.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #a0a6b0;
  transition: color 0.15s ease;
}
.tab.active {
  color: #07c160;
}
.tab-icon-wrap {
  position: relative;
}
.tab-dot {
  position: absolute;
  top: -2rpx;
  right: -8rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fa5151;
  border: 2rpx solid #ffffff;
}
.tab-icon {
  width: 46rpx;
  height: 46rpx;
  background-color: currentColor;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
  -webkit-mask-size: contain;
  mask-size: contain;
}
.tab-label {
  font-size: 20rpx;
  letter-spacing: 1rpx;
}
.tab.active .tab-label {
  font-weight: 600;
}

