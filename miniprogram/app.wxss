page {
  background: #f5f5f5;
  font-family: -apple-system, "PingFang SC", sans-serif;
  color: #333;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
}

.btn-primary[disabled] {
  background: #9be3b8;
  color: #fff;
}

.muted {
  color: #999;
  font-size: 26rpx;
}
