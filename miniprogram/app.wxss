page {
  background: #070d1b;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: #e2e8f0;
  min-height: 100vh;
}

.container {
  padding: 32rpx 28rpx 64rpx;
}

.card {
  background: #0c1526;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(34, 211, 238, 0.08);
  box-shadow: 0 4rpx 32rpx rgba(0, 0, 0, 0.4);
}

.btn-primary {
  background: linear-gradient(135deg, #0ea5e9, #22d3ee);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 20rpx rgba(34, 211, 238, 0.25);
}

.btn-primary[disabled] {
  opacity: 0.35;
  background: linear-gradient(135deg, #0ea5e9, #22d3ee);
  color: #fff;
  box-shadow: none;
}

.muted {
  color: #475569;
  font-size: 24rpx;
}
