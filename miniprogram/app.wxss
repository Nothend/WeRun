/* ============================================================
   设计系统 Design Tokens（极简留白 · 微信绿克制使用）
   全局定义在 page 上，靠 CSS 变量继承到各页面/组件。
   改主题只改这里：颜色 3 档灰阶、圆角 4 档、字号 6 档。
   ============================================================ */
page {
  /* ── 颜色 ── */
  --bg: #f5f6f8;          /* 页面背景：极淡冷灰 */
  --surface: #ffffff;     /* 卡片/前景 */
  --text-1: #16181d;      /* 主文字 */
  --text-2: #6b7280;      /* 次级文字 */
  --text-3: #a0a6b0;      /* 弱化 / meta / 占位 */
  --hairline: rgba(0, 0, 0, 0.06); /* 分隔线 */
  --brand: #07c160;       /* 品牌绿（克制使用：数字/达标/主按钮）*/
  --brand-press: #06ad56;
  --brand-soft: rgba(7, 193, 96, 0.08); /* 极少量品牌淡底 */
  --danger: #fa5151;

  /* ── 圆角 ── */
  --r-lg: 24rpx;          /* 大卡片 */
  --r-md: 16rpx;          /* 小元素 */
  --r-sm: 10rpx;
  --r-pill: 999rpx;

  /* ── 字号 ── */
  --fs-hero: 72rpx;       /* 主数字 */
  --fs-h1: 34rpx;
  --fs-h2: 30rpx;
  --fs-body: 28rpx;
  --fs-meta: 24rpx;
  --fs-cap: 22rpx;

  /* ── 阴影（极简：极淡单层，不与边框叠加）── */
  --shadow: 0 4rpx 24rpx rgba(17, 24, 39, 0.05);

  background: var(--bg);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: var(--text-1);
  min-height: 100vh;
  /* 给自定义 tabBar 让出底部空间 */
  --tabbar-h: calc(112rpx + env(safe-area-inset-bottom));
}

/* ── 基础布局 ── */
.container {
  padding: 24rpx 28rpx calc(48rpx + var(--tabbar-h));
}

.card {
  background: var(--surface);
  border-radius: var(--r-lg);
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

/* ── 主按钮（极简：纯色实底，轻阴影）── */
.btn-primary {
  background: var(--brand);
  color: #fff;
  border: none;
  border-radius: var(--r-md);
  font-weight: 600;
  letter-spacing: 1rpx;
}
.btn-primary[disabled] {
  opacity: 0.35;
  background: var(--brand);
  color: #fff;
}

.muted {
  color: var(--text-3);
  font-size: var(--fs-meta);
}

/* 通用区块标题（页面内小标题统一） */
.section-title {
  font-size: var(--fs-h2);
  font-weight: 700;
  color: var(--text-1);
  letter-spacing: 0.5rpx;
}

/* ── 单色线性图标（内联 SVG，currentColor 跟随文字色）──
   用法：<text class="icon icon-xxx" /> ，尺寸/颜色由 font-size/color 控制 */
.icon {
  display: inline-block;
  width: 1em;
  height: 1em;
  background-color: currentColor;
  -webkit-mask-repeat: no-repeat;
  mask-repeat: no-repeat;
  -webkit-mask-position: center;
  mask-position: center;
  -webkit-mask-size: contain;
  mask-size: contain;
  vertical-align: -0.125em;
  flex-shrink: 0;
}
