page {
  background: #f2f4f7;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: #1a1a1a;
  min-height: 100vh;
}

.container {
  padding: 32rpx 28rpx 64rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.25);
}

.btn-primary[disabled] {
  opacity: 0.35;
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #fff;
  box-shadow: none;
}

.muted {
  color: #8a9099;
  font-size: 24rpx;
}
