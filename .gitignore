# Dependencies
node_modules/
server/node_modules/

# Secrets — NEVER commit real config
.env
server/.env
*.local.env

# Runtime data (SQLite db + uploaded avatars)
server/data/
data/

# Logs
*.log
npm-debug.log*

# 更新日志：由 CI 从 git 标签自动生成并打入镜像，不手动维护、不入库
server/src/changelog.json

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# WeChat devtools
miniprogram/node_modules/

# 小程序本地真实配置（从 *.example 复制后填真实值；真实 baseUrl/appid 不进仓库）
miniprogram/config.js
miniprogram/project.config.json
# 开发者工具自动生成的个人私有配置（含 urlCheck 等本地调试开关），不应提交
miniprogram/project.private.config.json

# server 本地专用目录（样例截图、草稿、真实配置备份等），不进仓库
server/local/*
!server/local/README.md

# 本地运维小工具（多模型识别测速/测准网页），不进仓库
server/tools/

# 临时下载到 public 下分析的生产库副本，严禁入库（public/ 会被静态服务）
server/public/app.db*

# 本地运维/提审备忘、发版文案等，整个 docs 目录不进仓库
docs/
