# ===== WeRun 后端配置示例 =====
# 复制本文件为 .env 并填入真实值。.env 不会被提交到 Git。

# 微信小程序（mp.weixin.qq.com → 开发管理 → 开发设置）
APPID=wx_example_appid_xxxxxxxx
APPSECRET=example_appsecret_xxxxxxxxxxxxxxxxxxxx

# 千问 Qwen-VL（阿里云百炼 DashScope）API Key
DASHSCOPE_API_KEY=sk-example_dashscope_key_xxxxxxxx
# 可选：覆盖模型与端点
QWEN_MODEL=qwen-vl-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# JWT 签名密钥（随便一串长随机字符串，务必修改）
JWT_SECRET=please_change_me_to_a_long_random_string

# 对外可访问的 HTTPS 域名（用于拼接头像 URL），结尾不带斜杠
PUBLIC_BASE_URL=https://your.domain.com

# 服务监听端口（容器内）。宿主机端口在 docker-compose.yml 中映射为 9056，由 Caddy 反代。
PORT=3000

# 可选：指定首个管理员的 openid。留空则"第一个登录的用户"自动成为管理员。
BOOTSTRAP_ADMIN_OPENID=

# 打卡规则（一般无需修改）
MIN_DURATION_MINUTES=30
WEEKLY_TARGET=3

# 会员审核开关：true=用户提交申请后自动通过、立即成为正式成员；false（默认）=需管理员后台手动审核
AUTO_APPROVE_MEMBERS=false

# 赞助用户名单（逗号分隔）。名单内成员在排行榜、今日动态、个人主页享有「尊贵」
# 展示效果（金色光环头像 + 渐变昵称 + 徽标）。改完重启容器即生效，无需重新发版。
# 每项可在 openid 后加「:徽标」给该成员自定义徽标（emoji/短文案皆可），不写则用下方
# SPONSOR_BADGE 默认值。例：SPONSOR_OPENIDS=oXXXXXX1,oXXXXXX2:🍒,oXXXXXX3:🎀
#   → oXXXXXX1 用默认 💎，oXXXXXX2 用 🍒，oXXXXXX3 用 🎀
SPONSOR_OPENIDS=

# 赞助徽标默认文案：未在 SPONSOR_OPENIDS 里单独指定徽标的成员，跟在昵称后显示的小标记，
# 默认 💎。留空则这些成员不展示徽标（头像金环 + 昵称渐变仍保留）。改完重启容器即生效。
SPONSOR_BADGE=💎

# 截图运动日期允许的最大滞后天数：0=只允许今天，1=允许今天或昨天（默认，照顾晚上跑完次日早上打卡）
SCREENSHOT_MAX_LAG_DAYS=1

# 是否对打卡截图做微信内容安全检测：true（默认）=送检，平台合规要求；false=跳过检测提速但有合规风险。
# ⚠️ 改这个值后必须重建容器（docker compose up -d）才会生效——只改 .env 不重建不生效。
# 提审/正式运营期间务必保持 true，否则审核会判定"未对用户内容做安全检测"而打回。
SCREENSHOT_SEC_CHECK=true

# 「关于作者」页是否显示运营成本说明与赞赏码区块（小程序端实时从 /api/config 读取，
# 改完重启容器即生效，无需重新发版）。平台不允许个人主体小程序出现赞赏内容，
# 提审期间务必保持 false，开启与否风险自行权衡。
SHOW_SUPPORT=false

# 后台「成员管理」是否显示 Excel 历史数据导入功能（导入按钮+格式说明+待匹配记录）。
# 导入仅用于一次性历史数据迁移，平时隐藏保持后台简洁；需要导入时改 true 重启即可，
# 小程序端实时从 /api/config 读取，无需重新发版。
SHOW_IMPORT=false

# 防作弊：感知哈希(dHash)相似度日志阈值，256位中汉明距离 <= 此值时记录日志（不拦截）
# 用于积累真实样本判断是否启用拦截，默认20
IMAGE_SIMILARITY_LOG_THRESHOLD=20

# 防作弊：感知哈希(dHash)相似度拦截阈值，仅在「识别不到秒级时长」（无法用秒级指纹去重）时生效
# 汉明距离 <= 此值时直接拒绝打卡，比上面的日志阈值更严格，默认5，可据日志数据微调
IMAGE_SIMILARITY_BLOCK_THRESHOLD=5

# 订阅消息模板A：有新用户申请加入时通知管理员（mp.weixin.qq.com → 功能 → 订阅消息）
# 模板字段：thing1=申请人昵称  time2=申请时间  thing3=温馨提示
# 留空则用 config.js 内置的默认模板；换小程序/换模板时在此覆盖
APPLY_TEMPLATE_ID=

# 订阅消息模板B：每周日 22:00 自动推送本周打卡周报给全员
# 模板字段：thing7=活动名称  phrase4=完成状态  thing5=温馨提醒  thing1=运动计划  thing2=运动时长
# 留空则用 config.js 内置的默认模板；换小程序/换模板时在此覆盖
WEEKLY_TEMPLATE_ID=

# 部署用：ECS 上 docker-compose 拉取的镜像地址（与阿里云 ACR 仓库一致）
# 例如 registry.cn-hangzhou.aliyuncs.com/<namespace>/werun:latest
WERUN_IMAGE=registry.cn-hangzhou.aliyuncs.com/your-namespace/werun:latest
