# ===== WeRun 后端配置示例 =====
# 复制本文件为 .env 并填入真实值。.env 不会被提交到 Git。

# 微信小程序（mp.weixin.qq.com → 开发管理 → 开发设置）
APPID=wx_example_appid_xxxxxxxx
APPSECRET=example_appsecret_xxxxxxxxxxxxxxxxxxxx

# 千问 Qwen-VL（阿里云百炼 DashScope）API Key
DASHSCOPE_API_KEY=sk-example_dashscope_key_xxxxxxxx
# 可选：覆盖模型与端点
QWEN_MODEL=qwen-vl-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# JWT 签名密钥（随便一串长随机字符串，务必修改）
JWT_SECRET=please_change_me_to_a_long_random_string

# 对外可访问的 HTTPS 域名（用于拼接头像 URL），结尾不带斜杠
PUBLIC_BASE_URL=https://your.domain.com

# 服务监听端口（容器内）。宿主机端口在 docker-compose.yml 中映射为 9056，由 Caddy 反代。
PORT=3000

# 可选：指定首个管理员的 openid。留空则"第一个登录的用户"自动成为管理员。
BOOTSTRAP_ADMIN_OPENID=

# 打卡规则（一般无需修改）
MIN_DURATION_MINUTES=30
WEEKLY_TARGET=3

# 打卡通知（可选，旧模板，可留空）：管理员接收打卡通知所需的微信订阅消息模板 ID
# 在微信公众平台 → 功能 → 订阅消息 中创建模板，字段按以下顺序定义：
#   thing1  → 打卡成员（用户昵称，≤20字）
#   number2 → 运动时长(分钟)
#   phrase3 → 本周状态（如 "本周已达标" / "本周2/3次"）
#   date4   → 打卡时间（YYYY-MM-DD HH:mm）
# 留空则不发送微信通知，管理员仍可在后台查看打卡日志。
WECHAT_NOTIFY_TEMPLATE_ID=

# 订阅消息模板A：有新用户申请加入时通知管理员（mp.weixin.qq.com → 功能 → 订阅消息）
# 模板字段：thing1=申请人昵称  time2=申请时间  thing3=温馨提示
APPLY_TEMPLATE_ID=

# 订阅消息模板B：每周日 22:00 自动推送本周打卡周报给全员
# 模板字段：thing7=活动名称  phrase4=完成状态  thing5=温馨提醒  thing1=运动计划  thing2=运动时长
WEEKLY_TEMPLATE_ID=

# 部署用：ECS 上 docker-compose 拉取的镜像地址（与阿里云 ACR 仓库一致）
# 例如 registry.cn-hangzhou.aliyuncs.com/<namespace>/werun:latest
WERUN_IMAGE=registry.cn-hangzhou.aliyuncs.com/your-namespace/werun:latest
